---
interface Props {
  heading?: string;
  subtext?: string;
}

const {
  heading = "Ready to Try Bottleless?",
  subtext = "PureVida installs, maintains, and services everything. Free, no-obligation trial for Texas businesses."
} = Astro.props;
---

<section class="mt-12 bg-gradient-to-br from-sky-500 to-cyan-500 rounded-2xl p-8 md:p-12 text-center">
  <h2 class="text-2xl md:text-3xl font-bold text-white">{heading}</h2>
  <p class="mt-3 text-sky-100 text-lg max-w-xl mx-auto">{subtext}</p>
  <div class="mt-6 flex flex-col sm:flex-row gap-4 justify-center">
    <button data-trial-modal class="inline-flex items-center justify-center bg-white text-sky-600 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-sky-50 transition cursor-pointer shadow-lg">
      Request Free Trial
    </button>
    <a href="tel:+18885340117" class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/10 transition">
      Call (888) 534-0117
    </a>
  </div>
</section>

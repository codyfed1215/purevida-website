---
// Review redirect page: /review?place_id=XXX → Google review form
// Also fires GA4 event and optionally pings webhook
import '../styles/global.css'
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leave a Review | PureVida Water</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RT2GYZLRSW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RT2GYZLRSW');
  </script>

  <!-- Google Tag Manager -->
  <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NHL3XGV2');</script>

  <!-- Apollo.io tracking -->
  <script is:inline>function initApollo(){var n=Math.random().toString(36).substring(7),o=document.createElement("script");o.src="https://assets.apollo.io/micro/website-tracker/tracker.iife.js?nocache="+n,o.async=!0,o.defer=!0,o.onload=function(){window.trackingFunctions.onLoad({appId:"691da828d5e70a000d7a97f2"})},document.head.appendChild(o)}initApollo();</script>
</head>
<body class="min-h-screen bg-gradient-to-br from-sky-50 to-white flex items-center justify-center">
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NHL3XGV2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <div class="text-center p-8 max-w-md">
    <img src="/images/water-drop-logo.png" alt="PureVida" class="h-16 mx-auto mb-4" />
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Thanks for choosing PureVida!</h1>
    <p class="text-gray-600 mb-6">Redirecting you to leave a Google review...</p>
    <div class="animate-spin w-8 h-8 border-4 border-sky-500 border-t-transparent rounded-full mx-auto"></div>
  </div>

  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var placeId = params.get('place_id');

      if (!placeId) {
        document.querySelector('p').textContent = 'Missing place ID. Please use the link from your text message.';
        return;
      }

      // Fire GA4 event
      if (typeof gtag === 'function') {
        gtag('event', 'review_click', { event_category: 'review', place_id: placeId });
      }

      // Redirect to Google review form after brief delay
      setTimeout(function() {
        window.location.href = 'https://search.google.com/local/writereview?placeid=' + encodeURIComponent(placeId);
      }, 1500);
    })();
  </script>

<!--Start of Tawk.to Script-->
<script is:inline>
var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
(function(){
var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
s1.async=true;
s1.src='https://embed.tawk.to/69cece07b8aa781c3b30f63e/1jl7t9ji3';
s1.charset='UTF-8';
s1.setAttribute('crossorigin','*');
s0.parentNode.insertBefore(s1,s0);
})();
</script>
<!--End of Tawk.to Script-->

<!-- LinkedIn Insight Tag -->
<script type="text/javascript" is:inline>
_linkedin_partner_id = "9149124";
window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
window._linkedin_data_partner_ids.push(_linkedin_partner_id);
</script>
<script type="text/javascript" is:inline>
(function(l) {
if (!l){window.lintrk = function(a,b){window.lintrk.q.push([a,b])};
window.lintrk.q=[]}
var s = document.getElementsByTagName("script")[0];
var b = document.createElement("script");
b.type = "text/javascript";b.async = true;
b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
s.parentNode.insertBefore(b, s);})(window.lintrk);
</script>
<noscript>
<img height="1" width="1" style="display:none;" alt="" src="https://px.ads.linkedin.com/collect/?pid=9149124&fmt=gif" />
</noscript>

</body>
</html>

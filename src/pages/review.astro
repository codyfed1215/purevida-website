---
// Review redirect page: /review?place_id=XXX → Google review form
// Also fires GA4 event and optionally pings webhook
import '../styles/global.css'
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Leave a Review | PureVida Water</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RT2GYZLRSW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RT2GYZLRSW');
  </script>
</head>
<body class="min-h-screen bg-gradient-to-br from-sky-50 to-white flex items-center justify-center">
  <div class="text-center p-8 max-w-md">
    <img src="/images/water-drop-logo.png" alt="PureVida" class="h-16 mx-auto mb-4" />
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Thanks for choosing PureVida!</h1>
    <p class="text-gray-600 mb-6">Redirecting you to leave a Google review...</p>
    <div class="animate-spin w-8 h-8 border-4 border-sky-500 border-t-transparent rounded-full mx-auto"></div>
  </div>

  <script>
    (function() {
      var params = new URLSearchParams(window.location.search);
      var placeId = params.get('place_id');

      if (!placeId) {
        document.querySelector('p').textContent = 'Missing place ID. Please use the link from your text message.';
        return;
      }

      // Fire GA4 event
      if (typeof gtag === 'function') {
        gtag('event', 'review_click', { event_category: 'review', place_id: placeId });
      }

      // Redirect to Google review form after brief delay
      setTimeout(function() {
        window.location.href = 'https://search.google.com/local/writereview?placeid=' + encodeURIComponent(placeId);
      }, 1500);
    })();
  </script>
</body>
</html>

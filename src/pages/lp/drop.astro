---
// Canvasser Drop Form: Fox Flyer field team
// Standalone page — mobile-first, no shared Layout
// Route: /lp/drop
import '../../styles/global.css'

const SUPABASE_URL = 'https://tpqipscwaovlujxolfal.supabase.co';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FoxFlyer Drop | PureVida</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAsMm0WXezkhqAkKJ7B9pyU33gegoGbcfQ&libraries=places" async defer></script>
</head>

<body class="min-h-screen bg-gray-50 text-gray-900 antialiased">

  <!-- Header -->
  <header class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm">
    <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <img src="/images/water-drop-logo.png" alt="PureVida" class="h-7 w-auto" />
        <span class="text-base font-bold tracking-tight">
          <span class="text-sky-500">Fox</span><span class="text-gray-800">Flyer</span>
        </span>
      </div>
      <span class="text-xs text-gray-400 font-medium">Drop Form</span>
    </div>
  </header>

  <!-- Form -->
  <main class="max-w-lg mx-auto px-4 py-6">

    <!-- Card Scan Section -->
    <div class="bg-white rounded-xl border border-gray-200 p-4 mb-4 shadow-sm">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-gray-700">Smart Scan</h2>
        <span id="scan-status" class="text-xs text-gray-400 hidden">Extracting...</span>
      </div>

      <input type="file" id="card-input" accept="image/*" capture="environment" class="hidden" />

      <!-- Pre-scan state -->
      <button
        id="scan-btn"
        type="button"
        class="w-full border-2 border-dashed border-gray-300 rounded-lg py-8 flex flex-col items-center gap-2 text-gray-400 hover:border-sky-400 hover:text-sky-500 transition-colors cursor-pointer"
      >
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><circle cx="12" cy="13" r="3"/></svg>
        <span class="text-sm font-medium">Snap Business Card</span>
        <span class="text-xs">Auto-fills the form below</span>
      </button>

      <!-- Post-scan preview -->
      <div id="scan-preview" class="hidden">
        <img id="scan-img" class="w-full rounded-lg object-cover max-h-48" alt="Business card" />
        <button id="rescan-btn" type="button" class="mt-2 text-xs text-sky-500 font-medium hover:underline">Retake photo</button>
      </div>

      <!-- Scan error -->
      <p id="scan-error" class="text-xs text-red-500 mt-2 hidden"></p>
    </div>

    <!-- Main Form -->
    <form id="drop-form" class="space-y-3">

      <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm space-y-3">
        <h2 class="text-sm font-semibold text-gray-700 mb-1">Business Info</h2>

        <div>
          <label for="company" class="block text-xs font-medium text-gray-500 mb-1">Company *</label>
          <input type="text" id="company" name="company" required placeholder="Search business name..." autocomplete="off" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        </div>

        <div>
          <label for="phone" class="block text-xs font-medium text-gray-500 mb-1">Phone</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        </div>

        <div>
          <label for="address" class="block text-xs font-medium text-gray-500 mb-1">Address</label>
          <input type="text" id="address" name="address" placeholder="Start typing an address..." autocomplete="off" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
          <input type="hidden" id="google_place_id" name="google_place_id" />
        </div>

        <div>
          <label class="block text-xs font-medium text-gray-500 mb-2">Current Solution</label>
          <div class="flex flex-wrap gap-2">
            <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
              <input type="radio" name="current_solution" value="Jugs" class="accent-sky-500" /> Jugs
            </label>
            <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
              <input type="radio" name="current_solution" value="Individual Plastic Bottles" class="accent-sky-500" /> Bottles
            </label>
            <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
              <input type="radio" name="current_solution" value="Unknown" class="accent-sky-500" checked /> Unknown
            </label>
            <label class="flex items-center gap-1.5 text-sm text-gray-600 cursor-pointer">
              <input type="radio" name="current_solution" value="Other" class="accent-sky-500" /> Other
            </label>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm space-y-3">
        <h2 class="text-sm font-semibold text-gray-700 mb-1">Contact Info</h2>

        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="first_name" class="block text-xs font-medium text-gray-500 mb-1">First Name</label>
            <input type="text" id="first_name" name="first_name" placeholder="Jane" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
          </div>
          <div>
            <label for="last_name" class="block text-xs font-medium text-gray-500 mb-1">Last Name</label>
            <input type="text" id="last_name" name="last_name" placeholder="Smith" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
          </div>
        </div>

        <div>
          <label for="title" class="block text-xs font-medium text-gray-500 mb-1">Title</label>
          <input type="text" id="title" name="title" placeholder="Office Manager" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        </div>

        <div>
          <label for="email" class="block text-xs font-medium text-gray-500 mb-1">Email</label>
          <input type="email" id="email" name="email" placeholder="jane@acmecorp.com" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        </div>

        <div>
          <label for="mobile" class="block text-xs font-medium text-gray-500 mb-1">Mobile</label>
          <input type="tel" id="mobile" name="mobile" placeholder="(555) 987-6543" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        </div>

        <div>
          <label for="website" class="block text-xs font-medium text-gray-500 mb-1">Website</label>
          <input type="url" id="website" name="website" placeholder="www.acmecorp.com" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        </div>
      </div>

      <div class="bg-white rounded-xl border border-gray-200 p-4 shadow-sm">
        <h2 class="text-sm font-semibold text-gray-700 mb-2">Attribution</h2>
        <div>
          <label for="promo_code" class="block text-xs font-medium text-gray-500 mb-1">Promo Code</label>
          <input type="text" id="promo_code" name="promo_code" placeholder="e.g. PURE-SH" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base uppercase" maxlength="12" />
        </div>
      </div>

      <button
        type="submit"
        id="submit-btn"
        class="w-full bg-sky-500 hover:bg-sky-600 active:bg-sky-700 text-white font-semibold py-3.5 px-6 rounded-xl transition-colors text-base cursor-pointer shadow-lg shadow-sky-500/30 disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Submit Drop
      </button>
    </form>

    <!-- Success state -->
    <div id="success-state" class="hidden bg-white rounded-xl border border-green-200 p-8 text-center shadow-sm">
      <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h3 class="text-lg font-bold text-gray-900 mb-1">Drop Logged</h3>
      <p id="success-biz" class="text-sm text-gray-500 mb-4"></p>
      <button id="new-drop-btn" type="button" class="bg-sky-500 hover:bg-sky-600 text-white font-semibold py-3 px-8 rounded-xl transition-colors text-sm cursor-pointer">
        Next Drop
      </button>
    </div>
  </main>

  <!-- Toast -->
  <div id="toast" class="fixed top-4 left-1/2 -translate-x-1/2 z-[200] hidden">
    <div id="toast-inner" class="flex items-center gap-2 px-5 py-3 rounded-xl shadow-2xl text-white font-medium text-sm transition-all duration-300 opacity-0 -translate-y-4 bg-red-600">
      <span id="toast-msg">Something went wrong</span>
    </div>
  </div>

  <script define:vars={{ SUPABASE_URL }}>
    const API = SUPABASE_URL + '/functions/v1';

    // ---- Pre-fill promo from URL ----
    (function() {
      var initParams = new URLSearchParams(window.location.search);
      var initPromo = initParams.get('promo');
      if (initPromo) {
        var promoInput = document.getElementById('promo_code');
        if (promoInput) promoInput.value = initPromo.toUpperCase();
      }
    })();

    // ---- Phone formatting ----
    document.querySelectorAll('input[type="tel"]').forEach(function(input) {
      input.addEventListener('input', function(e) {
        var val = e.target.value.replace(/\D/g, '');
        if (val.length > 10) val = val.slice(0, 10);
        if (val.length >= 7) {
          val = '(' + val.slice(0, 3) + ') ' + val.slice(3, 6) + '-' + val.slice(6);
        } else if (val.length >= 4) {
          val = '(' + val.slice(0, 3) + ') ' + val.slice(3);
        } else if (val.length >= 1) {
          val = '(' + val;
        }
        e.target.value = val;
      });
    });

    // ---- Resize image to reduce payload ----
    function resizeImage(file, maxWidth) {
      return new Promise(function(resolve) {
        var img = new Image();
        var url = URL.createObjectURL(file);
        img.onload = function() {
          var scale = Math.min(1, maxWidth / img.width);
          var canvas = document.createElement('canvas');
          canvas.width = Math.round(img.width * scale);
          canvas.height = Math.round(img.height * scale);
          var ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
          URL.revokeObjectURL(url);
          resolve(canvas.toDataURL('image/jpeg', 0.6));
        };
        img.src = url;
      });
    }

    // ---- Google Places Autocomplete (on company name) ----
    var placeData = {};
    function initAutocomplete() {
      var companyInput = document.getElementById('company');
      var autocomplete = new google.maps.places.Autocomplete(companyInput, {
        componentRestrictions: { country: 'us' },
        types: ['establishment'],
        fields: ['address_components', 'formatted_address', 'formatted_phone_number', 'place_id', 'name', 'website'],
      });

      // Bias toward Texas
      autocomplete.setBounds(new google.maps.LatLngBounds(
        { lat: 25.8, lng: -106.6 },
        { lat: 36.5, lng: -93.5 }
      ));

      autocomplete.addListener('place_changed', function() {
        var place = autocomplete.getPlace();
        if (!place) return;

        placeData = {};
        var streetNum = '';
        var streetName = '';

        if (place.address_components) {
          for (var i = 0; i < place.address_components.length; i++) {
            var comp = place.address_components[i];
            var type = comp.types[0];
            if (type === 'street_number') streetNum = comp.long_name;
            if (type === 'route') streetName = comp.long_name;
            if (type === 'locality') placeData.city = comp.long_name;
            if (type === 'administrative_area_level_1') placeData.state = comp.short_name;
            if (type === 'postal_code') placeData.zip = comp.long_name;
          }
        }

        placeData.street = (streetNum + ' ' + streetName).trim();
        placeData.formatted = place.formatted_address || '';
        placeData.place_id = place.place_id || '';

        // Fill company name
        if (place.name) {
          companyInput.value = place.name;
        }

        // Fill address
        var addressInput = document.getElementById('address');
        if (placeData.street) {
          addressInput.value = placeData.street + (placeData.city ? ', ' + placeData.city + ', ' + (placeData.state || '') + ' ' + (placeData.zip || '') : '');
        } else if (placeData.formatted) {
          addressInput.value = placeData.formatted;
        }

        // Fill phone
        if (place.formatted_phone_number) {
          var phoneInput = document.getElementById('phone');
          if (!phoneInput.value) phoneInput.value = place.formatted_phone_number;
        }

        // Fill website
        if (place.website) {
          var websiteInput = document.getElementById('website');
          if (!websiteInput.value) websiteInput.value = place.website;
        }

        // Fill place ID
        document.getElementById('google_place_id').value = placeData.place_id;
      });
    }

    if (typeof google !== 'undefined' && google.maps) {
      initAutocomplete();
    } else {
      window.addEventListener('load', function() {
        if (typeof google !== 'undefined' && google.maps) initAutocomplete();
      });
    }

    // ---- Card Scan ----
    var scanBtn = document.getElementById('scan-btn');
    var rescanBtn = document.getElementById('rescan-btn');
    var cardInput = document.getElementById('card-input');
    var scanPreview = document.getElementById('scan-preview');
    var scanImg = document.getElementById('scan-img');
    var scanStatus = document.getElementById('scan-status');
    var scanError = document.getElementById('scan-error');

    scanBtn.addEventListener('click', function() { cardInput.click(); });
    rescanBtn.addEventListener('click', function() { cardInput.click(); });

    cardInput.addEventListener('change', async function(e) {
      var file = e.target.files[0];
      if (!file) return;

      // Show preview + resize for API
      scanBtn.classList.add('hidden');
      scanPreview.classList.remove('hidden');
      scanStatus.classList.remove('hidden');
      scanStatus.textContent = 'Resizing...';
      scanError.classList.add('hidden');

      try {
        var resized = await resizeImage(file, 800);
        scanImg.src = resized;
        scanStatus.textContent = 'Extracting...';

        // Strip data URL prefix — send only raw base64 to reduce payload
        var base64Only = resized.replace(/^data:image\/\w+;base64,/, '');

        var res = await fetch(API + '/scan-card', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ image: base64Only }),
        });
        var json = await res.json();

        if (json.ok && json.data) {
          var d = json.data;
          if (d.first_name) document.getElementById('first_name').value = d.first_name;
          if (d.last_name) document.getElementById('last_name').value = d.last_name;
          if (d.company) document.getElementById('company').value = d.company;
          if (d.title) document.getElementById('title').value = d.title;
          if (d.email) document.getElementById('email').value = d.email;
          if (d.phone) document.getElementById('phone').value = d.phone;
          if (d.mobile) document.getElementById('mobile').value = d.mobile;
          if (d.website) document.getElementById('website').value = d.website;
          if (d.address) {
            var addr = [d.address, d.city, d.state, d.zip].filter(Boolean).join(', ');
            document.getElementById('address').value = addr;
          }
          scanStatus.textContent = 'Fields filled';
          scanStatus.classList.add('text-green-500');
        } else {
          scanStatus.textContent = 'Could not read card';
          scanError.textContent = json.error || 'Try a clearer photo or enter manually.';
          scanError.classList.remove('hidden');
        }
      } catch (err) {
        scanStatus.textContent = 'Scan failed';
        scanError.textContent = err.message || 'Network error. Enter details manually.';
        scanError.classList.remove('hidden');
        console.error('scan error:', err);
        console.error('base64 payload size:', base64Only.length);
      }
    });

    // ---- Form Submit ----
    var form = document.getElementById('drop-form');
    var submitBtn = document.getElementById('submit-btn');
    var successState = document.getElementById('success-state');

    var submitting = false;
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (submitting) return;
      submitting = true;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      var solution = document.querySelector('input[name="current_solution"]:checked');

      var urlParams = new URLSearchParams(window.location.search);
      var urlPromo = urlParams.get('promo') || '';
      var promoValue = document.getElementById('promo_code').value.trim() || urlPromo || null;

      var payload = {
        source: 'foxflyer',
        form_type: 'drop',
        business_name: document.getElementById('company').value.trim(),
        phone: document.getElementById('phone').value.trim() || null,
        address: document.getElementById('address').value.trim() || null,
        first_name: document.getElementById('first_name').value.trim() || null,
        last_name: document.getElementById('last_name').value.trim() || null,
        title: document.getElementById('title').value.trim() || null,
        email: document.getElementById('email').value.trim() || null,
        mobile: document.getElementById('mobile').value.trim() || null,
        website: document.getElementById('website').value.trim() || null,
        current_solution: solution ? solution.value : null,
        google_place_id: document.getElementById('google_place_id').value || null,
        promo_code: promoValue,
      };

      // Use structured place data if available, otherwise parse from address string
      if (placeData.city) {
        payload.city = placeData.city;
        payload.state = placeData.state || null;
        payload.zip = placeData.zip || null;
        if (placeData.street) payload.address = placeData.street;
      } else {
        var addrVal = payload.address || '';
        var addrParts = addrVal.split(',').map(function(s) { return s.trim(); });
        if (addrParts.length >= 3) {
          var stateZip = addrParts[addrParts.length - 1].split(/\s+/);
          if (stateZip.length >= 2) {
            payload.state = stateZip[0];
            payload.zip = stateZip.slice(1).join(' ');
          }
          payload.city = addrParts[addrParts.length - 2];
        }
      }

      try {
        var res = await fetch(API + '/ingest-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var json = await res.json();

        if (json.ok) {
          form.classList.add('hidden');
          document.querySelector('.bg-white.rounded-xl.border.border-gray-200.p-4.mb-4').classList.add('hidden');
          successState.classList.remove('hidden');
          document.getElementById('success-biz').textContent = payload.business_name;
        } else {
          showToast(json.error || 'Submission failed');
          submitting = false;
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Drop';
        }
      } catch (err) {
        showToast('Network error — check connection');
        submitting = false;
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Drop';
      }
    });

    // ---- New Drop ----
    document.getElementById('new-drop-btn').addEventListener('click', function() {
      form.reset();
      form.classList.remove('hidden');
      document.querySelector('.bg-white.rounded-xl.border.border-gray-200.p-4.mb-4').classList.remove('hidden');
      successState.classList.add('hidden');
      submitting = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Drop';

      // Reset place data + scan
      placeData = {};
      document.getElementById('google_place_id').value = '';
      scanBtn.classList.remove('hidden');
      scanPreview.classList.add('hidden');
      scanStatus.classList.add('hidden');
      scanStatus.classList.remove('text-green-500');
      scanError.classList.add('hidden');
      cardInput.value = '';

      // Reset radio
      var unknownRadio = document.querySelector('input[name="current_solution"][value="Unknown"]');
      if (unknownRadio) unknownRadio.checked = true;
    });

    // ---- Toast ----
    function showToast(msg) {
      var toast = document.getElementById('toast');
      var inner = document.getElementById('toast-inner');
      document.getElementById('toast-msg').textContent = msg;
      toast.classList.remove('hidden');
      setTimeout(function() {
        inner.classList.remove('opacity-0', '-translate-y-4');
        inner.classList.add('opacity-100', 'translate-y-0');
      }, 10);
      setTimeout(function() {
        inner.classList.remove('opacity-100', 'translate-y-0');
        inner.classList.add('opacity-0', '-translate-y-4');
        setTimeout(function() { toast.classList.add('hidden'); }, 300);
      }, 4000);
    }
  </script>

</body>
</html>

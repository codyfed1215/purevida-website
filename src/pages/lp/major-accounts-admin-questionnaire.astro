<script>
  document.addEventListener('DOMContentLoaded', () => {
    const rankSelects = document.querySelectorAll('select[name^="q_rank_"]');
    rankSelects.forEach(select => {
      select.addEventListener('change', () => {
        const selected = select.value;
        if (!selected) return;
        rankSelects.forEach(other => {
          if (other !== select && other.value === selected) {
            other.value = '';
          }
        });
      });
    });
  });
</script>


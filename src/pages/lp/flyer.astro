---
// Landing Page: QR Code Flyer Campaign – Tap-Tap-Done Micro Funnel
// Standalone page — no shared Layout, no nav, no footer links
// Route: /lp/flyer
// Flow: Need (Water vs Water & Ice) → Consumption → Product Reveal + Form
import '../../styles/global.css'

const SUPABASE_URL = 'https://tpqipscwaovlujxolfal.supabase.co';
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Get Your Custom Quote | PureVida Water</title>
  <meta name="description" content="See what purified water costs for your office. Free installation included." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <script is:inline>(g=>{var h,a,k,p="The Google Maps JavaScript API",c="google",l="importLibrary",q="__ib__",m=document,b=window;b=b[c]||(b[c]={});var d=b.maps||(b.maps={}),r=new Set,e=new URLSearchParams,u=()=>h||(h=new Promise(async(f,n)=>{await (a=m.createElement("script"));e.set("libraries",[...r]+"");for(k in g)e.set(k.replace(/[A-Z]/g,t=>"_"+t[0].toLowerCase()),g[k]);e.set("callback",c+".maps."+q);a.src=`https://maps.googleapis.com/maps/api/js?`+e;d[q]=f;a.onerror=()=>h=n(Error(p+" could not load."));a.nonce=m.querySelector("script[nonce]")?.nonce||"";m.head.append(a)}));d[l]?console.warn(p+" already loaded"):d[l]=(f,...n)=>r.add(f)&&u().then(()=>d[l](f,...n))})({key:"AIzaSyAsMm0WXezkhqAkKJ7B9pyU33gegoGbcfQ",v:"weekly"});</script>

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RT2GYZLRSW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RT2GYZLRSW');
  </script>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NHL3XGV2');</script>

  <style is:global>
    .gm-err-container,.gm-err-title,.gm-err-message,.gm-err-autocomplete{display:none!important}
    .step { transition: opacity 0.3s ease, transform 0.3s ease; }
    .step.hidden { opacity: 0; transform: translateY(12px); pointer-events: none; position: absolute; }
    .step.visible { opacity: 1; transform: translateY(0); position: relative; }
    .tap-btn { transition: all 0.15s ease; }
    .tap-btn:active { transform: scale(0.97); }
    .price-reveal { animation: priceIn 0.4s ease-out; }
    @keyframes priceIn {
      from { opacity: 0; transform: scale(0.85); }
      to { opacity: 1; transform: scale(1); }
    }
    .product-reveal { animation: productIn 0.5s ease-out; }
    @keyframes productIn {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>

<body class="min-h-screen bg-white text-gray-900 antialiased">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NHL3XGV2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- ============ SLIM HEADER ============ -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-gray-200">
    <div class="max-w-lg mx-auto px-4 py-3 flex items-center justify-between">
      <a href="https://purevidawater.com" class="flex items-center gap-2 shrink-0">
        <img src="/images/water-drop-logo.png" alt="PureVida" class="h-8 w-auto" />
        <span class="text-lg font-bold tracking-tight">
          <span class="text-sky-500">Pure</span><span class="text-sky-800">Vida</span>
        </span>
      </a>
      <a href="tel:+18885340117" class="flex items-center gap-1.5 text-gray-600 hover:text-sky-500 transition-colors text-sm font-medium">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        <span>(888) 534-0117</span>
      </a>
    </div>
  </header>

  <!-- ============ MICRO FUNNEL ============ -->
  <main class="max-w-lg mx-auto px-4 py-8 min-h-[70vh] flex flex-col justify-center">

    <!-- ---- Step 1: What do you need? ---- -->
    <div id="step-1" class="step visible">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">What does your office need?</h1>
        <p class="mt-2 text-gray-500">We'll recommend the perfect system for you</p>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <button data-need="water" class="tap-btn need-btn bg-white border-2 border-gray-200 rounded-2xl py-5 text-center cursor-pointer hover:border-sky-400 active:border-sky-500 flex flex-col items-center">
          <img src="/images/products/PV3w.png" alt="Water Cooler" class="h-16 w-auto object-contain mb-2" />
          <span class="block text-sm font-bold text-gray-900">Water</span>
          <span class="block text-[11px] text-gray-500 mt-0.5">Hot &amp; Cold</span>
        </button>
        <button data-need="ice" class="tap-btn need-btn bg-white border-2 border-gray-200 rounded-2xl py-5 text-center cursor-pointer hover:border-sky-400 active:border-sky-500 flex flex-col items-center">
          <img src="/images/products/PV8i.png" alt="Ice & Water Machine" class="h-16 w-auto object-contain mb-2" />
          <span class="block text-sm font-bold text-gray-900">Water &amp; Ice</span>
          <span class="block text-[11px] text-gray-500 mt-0.5">Water + Ice Maker</span>
        </button>
        <button data-need="coffee" class="tap-btn need-btn bg-white border-2 border-gray-200 rounded-2xl py-5 text-center cursor-pointer hover:border-sky-400 active:border-sky-500 flex flex-col items-center">
          <img src="/images/products/PV12c.png" alt="Coffee System" class="h-16 w-auto object-contain mb-2" />
          <span class="block text-sm font-bold text-gray-900">Coffee</span>
          <span class="block text-[11px] text-gray-500 mt-0.5">Bean to Cup</span>
        </button>
      </div>
    </div>

    <!-- ---- Step 2: Consumption Level ---- -->
    <div id="step-2" class="step hidden">
      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">How many drinkers?</h1>
        <p class="mt-2 text-gray-500">We'll match you with the right system</p>
      </div>
      <div class="grid grid-cols-1 gap-3">
        <button data-consumption="low" class="tap-btn consumption-btn bg-white border-2 border-gray-200 rounded-2xl py-5 px-6 cursor-pointer hover:border-sky-400 active:border-sky-500 flex items-center gap-4">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center shrink-0">
            <span class="text-xl font-bold text-sky-600">S</span>
          </div>
          <div class="text-left">
            <span class="block text-base font-bold text-gray-900">Up to 7 Drinkers</span>
            <span class="block text-sm text-gray-500">Low consumption</span>
          </div>
        </button>
        <button data-consumption="moderate" class="tap-btn consumption-btn bg-white border-2 border-gray-200 rounded-2xl py-5 px-6 cursor-pointer hover:border-sky-400 active:border-sky-500 flex items-center gap-4">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center shrink-0">
            <span class="text-xl font-bold text-sky-600">M</span>
          </div>
          <div class="text-left">
            <span class="block text-base font-bold text-gray-900">7–30 Drinkers</span>
            <span class="block text-sm text-gray-500">Moderate consumption</span>
          </div>
        </button>
        <button data-consumption="high" class="tap-btn consumption-btn bg-white border-2 border-gray-200 rounded-2xl py-5 px-6 cursor-pointer hover:border-sky-400 active:border-sky-500 flex items-center gap-4">
          <div class="w-12 h-12 bg-sky-50 rounded-xl flex items-center justify-center shrink-0">
            <span class="text-xl font-bold text-sky-600">L</span>
          </div>
          <div class="text-left">
            <span class="block text-base font-bold text-gray-900">30+ Drinkers</span>
            <span class="block text-sm text-gray-500">High consumption</span>
          </div>
        </button>
      </div>
      <button id="back-to-1" class="mt-4 text-sm text-gray-400 hover:text-gray-600 cursor-pointer bg-transparent border-none mx-auto block">&larr; Back</button>
    </div>

    <!-- ---- Step 3: Product Reveal + Form ---- -->
    <div id="step-3" class="step hidden">
      <!-- Product Card -->
      <div class="bg-gray-50 rounded-2xl p-6 mb-6 text-center product-reveal">
        <img id="product-image" src="" alt="" class="h-40 w-auto object-contain mx-auto mb-4" />
        <h2 id="product-name" class="text-xl font-bold text-gray-900"></h2>
        <p id="product-subtitle" class="text-sm text-gray-500 mt-1"></p>
        <div class="mt-4">
          <span id="product-price" class="text-4xl font-bold text-gray-900 price-reveal"></span>
          <span class="text-gray-500 text-lg">/mo</span>
        </div>
        <p class="text-sm text-sky-600 font-medium mt-2">Free installation &amp; maintenance included</p>
      </div>

      <!-- Form -->
      <form id="lead-form" class="space-y-3">
        <input type="text" id="inp-name" required placeholder="Your name" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        <input type="text" id="inp-business" required placeholder="Company name" autocomplete="off" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        <input type="text" id="inp-address" required placeholder="Business address" autocomplete="off" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        <input type="hidden" id="inp-place-id" />
        <input type="tel" id="inp-phone" required placeholder="Phone number" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        <input type="email" id="inp-email" required placeholder="Email address" class="w-full px-4 py-3.5 border border-gray-300 rounded-xl focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-base" />
        <button type="submit" id="submit-btn" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-4 px-6 rounded-xl transition-colors text-lg cursor-pointer shadow-lg shadow-sky-500/25 disabled:opacity-50 disabled:cursor-not-allowed">
          Claim Free Install &rarr;
        </button>
      </form>
      <button id="back-to-2" class="mt-4 text-sm text-gray-400 hover:text-gray-600 cursor-pointer bg-transparent border-none mx-auto block">&larr; Back</button>
    </div>

    <!-- ---- Success State ---- -->
    <div id="step-success" class="step hidden text-center">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-5">
        <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      </div>
      <h2 class="text-2xl font-bold text-gray-900 mb-2">You're All Set!</h2>
      <p class="text-gray-600">Expect a call from our team shortly to get you started.</p>
      <p class="text-sm text-gray-400 mt-4">Free installation &bull; No obligation</p>
    </div>

  </main>

  <!-- ============ TRUST BAR ============ -->
  <div id="trust-bar" class="border-t border-gray-100 bg-gray-50 py-6">
    <div class="max-w-lg mx-auto px-4">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div>
          <p class="text-lg font-bold text-gray-900">1,100+</p>
          <p class="text-xs text-gray-500">Businesses Served</p>
        </div>
        <div>
          <p class="text-lg font-bold text-gray-900">30–80%</p>
          <p class="text-xs text-gray-500">Cost Savings</p>
        </div>
        <div>
          <p class="text-lg font-bold text-gray-900">99.9%</p>
          <p class="text-xs text-gray-500">Contaminants Removed</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ============ MINIMAL FOOTER ============ -->
  <footer class="bg-gray-900 text-white py-6">
    <div class="max-w-lg mx-auto px-4 text-center">
      <p class="font-semibold mb-1">PureVida Water</p>
      <a href="tel:+18885340117" class="text-gray-400 hover:text-white transition-colors text-sm">(888) 534-0117</a>
      <p class="text-gray-500 text-xs mt-2">&copy; 2026 PureVida Water. All rights reserved.</p>
    </div>
  </footer>

  <!-- Toast Notification -->
  <div id="toast" class="fixed top-6 left-1/2 -translate-x-1/2 z-[200] hidden">
    <div id="toast-inner" class="flex items-center gap-3 px-6 py-4 rounded-xl shadow-2xl text-white font-medium transition-all duration-300 opacity-0 -translate-y-4 bg-green-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
      <span>You're all set! We'll be in touch.</span>
    </div>
  </div>

  <!-- ============ SCRIPTS ============ -->
  <script define:vars={{ SUPABASE_URL }}>
    var API = SUPABASE_URL + '/functions/v1';

    // ---- State ----
    var funnelState = {
      need: null,        // 'water' or 'ice'
      consumption: null, // 'low', 'moderate', 'high'
      product: null,     // product key
    };

    // ---- Product recommendation map ----
    // Based on need + consumption, recommend a specific product
    // Prices are 60-month rental grid prices
    var PRODUCTS = {
      PV2w: {
        name: 'PV2w',
        subtitle: 'Countertop Water Cooler',
        image: '/images/products/PV2w.png',
        price: 54,
      },
      PV3w: {
        name: 'PV3w',
        subtitle: 'Freestanding Water Cooler',
        image: '/images/products/PV3w.png',
        price: 74,
      },
      PV4w: {
        name: 'PV4w',
        subtitle: 'High-Capacity Hydration Hub',
        image: '/images/products/PV4w.png',
        price: 159,
      },
      PV6i: {
        name: 'PV6i',
        subtitle: 'Countertop Ice & Water',
        image: '/images/products/PV6i.png',
        price: 119,
      },
      PV8i: {
        name: 'PV8i',
        subtitle: 'Freestanding Ice & Water',
        image: '/images/products/PV8i.png',
        price: 209,
      },
      PV9i: {
        name: 'PV9i',
        subtitle: 'High-Capacity Ice & Water',
        image: '/images/products/PV9i.png',
        price: 309,
      },
      PV12c: {
        name: 'PV12c',
        subtitle: 'Bean to Cup Coffee System',
        image: '/images/products/PV12c.png',
        price: 275,
      },
    };

    var RECOMMENDATIONS = {
      water: {
        low:      'PV2w',
        moderate: 'PV3w',
        high:     'PV4w',
      },
      ice: {
        low:      'PV6i',
        moderate: 'PV8i',
        high:     'PV9i',
      },
    };

    // ---- Step transitions ----
    function showStep(id) {
      var steps = document.querySelectorAll('.step');
      for (var i = 0; i < steps.length; i++) {
        steps[i].classList.remove('visible');
        steps[i].classList.add('hidden');
      }
      var target = document.getElementById(id);
      setTimeout(function() {
        target.classList.remove('hidden');
        target.classList.add('visible');
      }, 50);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ---- Helper: populate product card and go to step 3 ----
    function showProductReveal(productKey) {
      funnelState.product = productKey;
      var product = PRODUCTS[productKey];
      document.getElementById('product-image').src = product.image;
      document.getElementById('product-image').alt = product.name;
      document.getElementById('product-name').textContent = product.name;
      document.getElementById('product-subtitle').textContent = product.subtitle;
      document.getElementById('product-price').textContent = '$' + product.price;
      setTimeout(function() { showStep('step-3'); }, 200);
    }

    // ---- Step 1: Need ----
    var needBtns = document.querySelectorAll('.need-btn');
    for (var i = 0; i < needBtns.length; i++) {
      needBtns[i].addEventListener('click', function() {
        funnelState.need = this.getAttribute('data-need');
        for (var j = 0; j < needBtns.length; j++) {
          needBtns[j].classList.remove('border-sky-500', 'bg-sky-50');
        }
        this.classList.add('border-sky-500', 'bg-sky-50');

        // Coffee skips consumption — only one product
        if (funnelState.need === 'coffee') {
          funnelState.consumption = null;
          showProductReveal('PV12c');
        } else {
          setTimeout(function() { showStep('step-2'); }, 200);
        }
      });
    }

    // ---- Step 2: Consumption ----
    var consBtns = document.querySelectorAll('.consumption-btn');
    for (var i = 0; i < consBtns.length; i++) {
      consBtns[i].addEventListener('click', function() {
        funnelState.consumption = this.getAttribute('data-consumption');
        for (var j = 0; j < consBtns.length; j++) {
          consBtns[j].classList.remove('border-sky-500', 'bg-sky-50');
        }
        this.classList.add('border-sky-500', 'bg-sky-50');

        var productKey = RECOMMENDATIONS[funnelState.need][funnelState.consumption];
        showProductReveal(productKey);
      });
    }

    // ---- Back buttons ----
    document.getElementById('back-to-1').addEventListener('click', function() { showStep('step-1'); });
    document.getElementById('back-to-2').addEventListener('click', function() {
      showStep(funnelState.need === 'coffee' ? 'step-1' : 'step-2');
    });

    // ---- Phone Formatting ----
    var phoneInput = document.getElementById('inp-phone');
    phoneInput.addEventListener('input', function(e) {
      var val = e.target.value.replace(/\D/g, '');
      if (val.length > 10) val = val.slice(0, 10);
      if (val.length >= 7) {
        val = '(' + val.slice(0, 3) + ') ' + val.slice(3, 6) + '-' + val.slice(6);
      } else if (val.length >= 4) {
        val = '(' + val.slice(0, 3) + ') ' + val.slice(3);
      } else if (val.length >= 1) {
        val = '(' + val;
      }
      e.target.value = val;
    });

    // ---- Pre-fill promo from URL ----
    var urlParams = new URLSearchParams(window.location.search);
    var urlSource = urlParams.get('source') || 'qr_scan';
    var urlPromo = urlParams.get('promo') || '';

    // ---- Google Places Autocomplete (on address field) ----
    var placeData = {};
    async function initAutocomplete() {
      try { await google.maps.importLibrary('places'); } catch(e) { return; }
      var addressInput = document.getElementById('inp-address');
      var autocomplete = new google.maps.places.Autocomplete(addressInput, {
        componentRestrictions: { country: 'us' },
        types: ['address'],
        fields: ['address_components', 'formatted_address', 'place_id'],
      });

      autocomplete.setBounds(new google.maps.LatLngBounds(
        { lat: 25.8, lng: -106.6 },
        { lat: 36.5, lng: -93.5 }
      ));

      autocomplete.addListener('place_changed', function() {
        var place = autocomplete.getPlace();
        if (!place) return;

        placeData = {};
        var streetNum = '';
        var streetName = '';

        if (place.address_components) {
          for (var i = 0; i < place.address_components.length; i++) {
            var comp = place.address_components[i];
            var type = comp.types[0];
            if (type === 'street_number') streetNum = comp.long_name;
            if (type === 'route') streetName = comp.long_name;
            if (type === 'locality') placeData.city = comp.long_name;
            if (type === 'administrative_area_level_1') placeData.state = comp.short_name;
            if (type === 'postal_code') placeData.zip = comp.long_name;
          }
        }

        placeData.street = (streetNum + ' ' + streetName).trim();
        placeData.place_id = place.place_id || '';

        if (placeData.street) {
          addressInput.value = placeData.street + (placeData.city ? ', ' + placeData.city + ', ' + (placeData.state || '') + ' ' + (placeData.zip || '') : '');
        } else if (place.formatted_address) {
          addressInput.value = place.formatted_address;
        }

        document.getElementById('inp-place-id').value = placeData.place_id;
      });
    }
    initAutocomplete();

    // ---- Form Submit → ingest-lead ----
    var form = document.getElementById('lead-form');
    var submitBtn = document.getElementById('submit-btn');
    var submitting = false;

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (submitting) return;
      submitting = true;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      var fullName = document.getElementById('inp-name').value.trim();
      var nameParts = fullName.split(/\s+/);
      var firstName = nameParts[0] || '';
      var lastName = nameParts.slice(1).join(' ') || '';

      var payload = {
        source: urlSource,
        form_type: 'flyer',
        business_name: document.getElementById('inp-business').value.trim(),
        address: document.getElementById('inp-address').value.trim() || null,
        city: placeData.city || null,
        state: placeData.state || null,
        zip: placeData.zip || null,
        google_place_id: document.getElementById('inp-place-id').value || null,
        phone: document.getElementById('inp-phone').value.trim() || null,
        email: document.getElementById('inp-email').value.trim() || null,
        first_name: firstName || null,
        last_name: lastName || null,
        current_solution: funnelState.need === 'ice' ? 'Water & Ice' : 'Water',
        promo_code: urlPromo || null,
        recommended_product: funnelState.product || null,
        estimated_price: PRODUCTS[funnelState.product] ? PRODUCTS[funnelState.product].price : null,
      };

      // Parse address into structured fields if Places wasn't used
      if (!placeData.city && payload.address) {
        var addrParts = payload.address.split(',').map(function(s) { return s.trim(); });
        if (addrParts.length >= 3) {
          var stateZip = addrParts[addrParts.length - 1].split(/\s+/);
          if (stateZip.length >= 2) {
            payload.state = stateZip[0];
            payload.zip = stateZip.slice(1).join(' ');
          }
          payload.city = addrParts[addrParts.length - 2];
        }
      }

      try {
        var res = await fetch(API + '/ingest-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var json = await res.json();

        if (json.ok) {
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', {
              event_category: 'form',
              event_label: 'flyer_lp',
              need: funnelState.need,
              consumption: funnelState.consumption,
              recommended_product: funnelState.product,
            });
          }
          showStep('step-success');
          showToast();
        } else {
          alert(json.error || 'Something went wrong. Please try again.');
          submitting = false;
          submitBtn.disabled = false;
          submitBtn.innerHTML = 'Claim Free Install &rarr;';
        }
      } catch (err) {
        alert('Network error. Please check your connection and try again.');
        submitting = false;
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Claim Free Install &rarr;';
      }
    });

    // ---- Toast ----
    function showToast() {
      var toast = document.getElementById('toast');
      var inner = document.getElementById('toast-inner');
      if (!toast || !inner) return;
      toast.classList.remove('hidden');
      setTimeout(function() {
        inner.classList.remove('opacity-0', '-translate-y-4');
        inner.classList.add('opacity-100', 'translate-y-0');
      }, 10);
      setTimeout(function() {
        inner.classList.remove('opacity-100', 'translate-y-0');
        inner.classList.add('opacity-0', '-translate-y-4');
        setTimeout(function() { toast.classList.add('hidden'); }, 300);
      }, 4000);
    }
  </script>

</body>
</html>

  <script define:vars={{ SUPABASE_URL }}>
    var API = SUPABASE_URL + '/functions/v1';

    // Rotating word animation
    var words = ['Business.', 'Warehouse.', 'Breakroom.', 'Lobby.', 'School.', 'Hospital.', 'Gym.', 'Business.'];
    var rotatingWord = document.getElementById('rotating-word');
    var wordIndex = 0;

    function updateWord() {
      rotatingWord.style.opacity = '0';
      rotatingWord.style.transform = 'translateY(10px)';
      setTimeout(function() {
        rotatingWord.textContent = words[wordIndex];
        rotatingWord.style.opacity = '1';
        rotatingWord.style.transform = 'translateY(0)';
        wordIndex = (wordIndex + 1) % words.length;
      }, 400);
    }

    rotatingWord.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
    updateWord();
    setInterval(updateWord, 3000);

    // ---- Shared helpers ----
    function formatPhone(e) {
      var val = e.target.value.replace(/\D/g, '');
      if (val.length > 10) val = val.slice(0, 10);
      if (val.length >= 7) {
        val = '(' + val.slice(0, 3) + ') ' + val.slice(3, 6) + '-' + val.slice(6);
      } else if (val.length >= 4) {
        val = '(' + val.slice(0, 3) + ') ' + val.slice(3);
      } else if (val.length >= 1) {
        val = '(' + val;
      }
      e.target.value = val;
    }

    function getBranch(city) {
      if (city === 'Greater Austin Metro') return 'ATX';
      if (city === 'Greater San Antonio Metro') return 'SAN';
      return 'DFW';
    }

    // Track selected product
    var selectedProduct = null;

    async function submitForm(payload, btn, btnText) {
      try {
        var res = await fetch(API + '/ingest-lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var json = await res.json();

        if (json.ok) {
          if (typeof gtag === 'function') {
            gtag('event', 'generate_lead', {
              event_category: 'form',
              event_label: 'google_ads_vida_mobile',
              city: payload.city,
            });
          }
          window.location.href = '/free-trial-thank-you';
        } else {
          alert(json.error || 'Something went wrong. Please try again.');
          return false;
        }
      } catch (err) {
        alert('Network error. Please check your connection and try again.');
        return false;
      }
      return true;
    }

    // ---- Phone formatting ----
    document.getElementById('modal-phone').addEventListener('input', formatPhone);

    // ---- Modal ----
    var modal = document.getElementById('trial-modal');
    var backdrop = document.getElementById('modal-backdrop');
    var modalContent = document.getElementById('modal-content');
    var closeBtn = document.getElementById('modal-close');

    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(function() {
        backdrop.classList.remove('opacity-0');
        backdrop.classList.add('opacity-100');
        modalContent.classList.remove('translate-y-full', 'sm:translate-y-8', 'sm:scale-95', 'opacity-0');
        modalContent.classList.add('translate-y-0', 'sm:translate-y-0', 'sm:scale-100', 'opacity-100');
      }, 10);
    }

    function closeModal() {
      backdrop.classList.remove('opacity-100');
      backdrop.classList.add('opacity-0');
      modalContent.classList.add('translate-y-full', 'sm:translate-y-8', 'sm:scale-95', 'opacity-0');
      modalContent.classList.remove('translate-y-0', 'sm:translate-y-0', 'sm:scale-100', 'opacity-100');
      document.body.style.overflow = '';
      setTimeout(function() { modal.classList.add('hidden'); }, 300);
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-open-modal]');
      if (btn) {
        e.preventDefault();
        var productLine = document.getElementById('modal-product-line');
        if (btn.dataset.productKey) {
          selectedProduct = { key: btn.dataset.productKey, name: btn.dataset.productName, price: Number(btn.dataset.productPrice) };
          productLine.textContent = selectedProduct.name + ' — $' + selectedProduct.price + '/mo';
          productLine.classList.remove('hidden');
        } else {
          selectedProduct = null;
          productLine.classList.add('hidden');
        }
        openModal();
      }
    });

    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);

    // ---- Modal form submit ----
    var modalForm = document.getElementById('modal-form');
    var modalSubmitBtn = document.getElementById('modal-submit-btn');
    var modalSubmitting = false;

    modalForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      if (modalSubmitting) return;
      modalSubmitting = true;
      modalSubmitBtn.disabled = true;
      modalSubmitBtn.textContent = 'Submitting...';

      var cityVal = document.getElementById('modal-city').value;
      var payload = {
        source: 'google_ads',
        form_type: 'contact',
        business_name: document.getElementById('modal-company').value.trim(),
        first_name: document.getElementById('modal-fname').value.trim() || null,
        last_name: document.getElementById('modal-lname').value.trim() || null,
        email: document.getElementById('modal-email').value.trim() || null,
        phone: document.getElementById('modal-phone').value.trim() || null,
        city: cityVal || null,
        branch: getBranch(cityVal),
        promo_code: document.getElementById('modal-promo').value.trim().toUpperCase() || null,
      };
      if (selectedProduct) {
        payload.recommended_product = selectedProduct.key;
        payload.estimated_price = selectedProduct.price;
      }

      var ok = await submitForm(payload, modalSubmitBtn, 'Request Free Trial');
      if (!ok) {
        modalSubmitting = false;
        modalSubmitBtn.disabled = false;
        modalSubmitBtn.textContent = 'Request Free Trial';
      }
    });
  </script>


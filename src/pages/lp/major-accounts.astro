              <td style="padding:12px 16px;border:1px solid #cbd5e1;text-align:center;color:#dc2626;">&#10007;</td>
              <td style="padding:12px 16px;border:1px solid #cbd5e1;text-align:center;">Depends on usage</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p style="font-size:12px;color:#94a3b8;margin-top:12px;text-align:center;">*Applies only with annual maintenance renewal each year.</p>
    </div>
  </section>

  <!-- ============ FOOTER ============ -->
  <footer class="bg-gray-900 text-white py-6 mt-10">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="font-semibold mb-1">PureVida Water</p>
      <a href="mailto:contact@purevidawater.com" class="text-gray-400 hover:text-white transition-colors text-sm">contact@purevidawater.com</a>
      <span class="text-gray-600 mx-2">|</span>
      <a href="tel:+18885340117" class="text-gray-400 hover:text-white transition-colors text-sm">(888) 534-0117</a>
      <p class="text-gray-500 text-xs mt-2">&copy; 2026 PureVida Water. All rights reserved.</p>
    </div>
  </footer>

  <script define:vars={{ SUPABASE_URL }}>
    // ================================================================
    // PRICING DATA
    // ================================================================
    const MODELS = {
      PV1w: { label: 'PV1w — Low Consumption Water CT', grid: { 60: 54, 36: 68, 12: 82 }, cost: 576, category: 'water' },
      PV2w: { label: 'PV2w — Low Consumption Water', grid: { 60: 54, 36: 68, 12: 82 }, cost: 576, category: 'water' },
      PV3w: { label: 'PV3w — Moderate Consumption Water', grid: { 60: 74, 36: 94, 12: 114 }, cost: 870, category: 'water' },
      PV4w: { label: 'PV4w — High Consumption Water', grid: { 60: 159, 36: 189, 12: 219 }, cost: 1995, category: 'water' },
      PV5s: { label: 'PV5s — Sparkling Water', grid: { 60: 134, 36: 154, 12: 174 }, cost: 861, category: 'water' },
      PV6i: { label: 'PV6i — Low Consumption Water & Ice', grid: { 60: 119, 36: 139, 12: 159 }, cost: 1321, category: 'ice' },
      PV7i: { label: 'PV7i — Low Consumption Water & Ice', grid: { 60: 179, 36: 209, 12: 239 }, cost: 2916, category: 'ice' },
      PV8i: { label: 'PV8i — Moderate Consumption Water & Ice', grid: { 60: 209, 36: 239, 12: 269 }, cost: 3328, category: 'ice' },
      PV9i: { label: 'PV9i — High Consumption Water & Ice', grid: { 60: 309, 36: 349, 12: 389 }, cost: 6566, category: 'ice' },
      PV12c: { label: 'PV12c — Coffee', grid: { 60: 275, 36: 315, 12: 355 }, cost: 5028, category: 'ice' }
    };

    const INSTALL_FEE = 99;
    const DISCOUNTS = { 60: 0.75, 36: 0.85, 12: 1.00 };
    const MAINT_FEES = { water: 189, ice: 249 };
    const TRIP_CHARGE = 169;

    // ================================================================
    // STATE
    // ================================================================
    let state = {
      systems: [],          // [{ model: 'PV3w', qty: 2, customPrice: null }, ...]
      addModel: 'PV1w',     // currently selected in the dropdown for adding
      addQty: 1,            // currently selected qty for adding
      rentalTerm: 60,
      tpTerm: 60,
      trips: 2,
      yearRange: 5,
      lastViewedOption: 'Option 1 — Full-Service Rental'
    };

    // Series definitions
    const SERIES_DEFS = [
      { key: 'rental60',  label: 'Rental 60-mo',       color: '#378ADD', dash: [],     defaultOn: true },
      { key: 'rental36',  label: 'Rental 36-mo',       color: '#60a5fa', dash: [6,3],  defaultOn: false },
      { key: 'rental12',  label: 'Rental 12-mo',       color: '#93c5fd', dash: [3,3],  defaultOn: false },
      { key: 'tp60',      label: 'Time Purchase 60-mo', color: '#14A38B', dash: [],     defaultOn: true },
      { key: 'tp36',      label: 'Time Purchase 36-mo', color: '#34d399', dash: [6,3],  defaultOn: false },
      { key: 'tp12',      label: 'Time Purchase 12-mo', color: '#6ee7b7', dash: [3,3],  defaultOn: false },
      { key: 'maint',     label: 'Purchase + Maint.',   color: '#D97706', dash: [],     defaultOn: true },
      { key: 'tm',        label: 'Purchase + T&M',      color: '#DC2626', dash: [],     defaultOn: true }
    ];

    let seriesVisible = {};
    SERIES_DEFS.forEach(s => { seriesVisible[s.key] = s.defaultOn; });

    // ================================================================
    // DOM REFS
    // ================================================================
    const modelSelect = document.getElementById('model-select');
    const qtyDisplay = document.getElementById('qty-display');
    const qtyMinus = document.getElementById('qty-minus');
    const qtyPlus = document.getElementById('qty-plus');
    const customPriceInput = document.getElementById('custom-price');
    const addSystemBtn = document.getElementById('add-system-btn');
    const tripsSlider = document.getElementById('trips-slider');
    const tripsDisplay = document.getElementById('trips-display');

    // ================================================================
    // HELPERS
    // ================================================================
    function fmt(n) {
      return '$' + n.toLocaleString('en-US', { maximumFractionDigits: 0 });
    }

    function fmtK(n) {
      if (n >= 1000) {
        return '$' + (n / 1000).toFixed(n % 1000 === 0 ? 0 : 1) + 'k';
      }
      return '$' + n.toFixed(0);
    }

    function roundTo10(n) {
      return Math.round(n / 10) * 10;
    }

    function getTotalUnits() {
      return state.systems.reduce((sum, s) => sum + s.qty, 0);
    }

    function getTotalInstallFee() {
      return getTotalUnits() * INSTALL_FEE;
    }

    // Option 3 sell price per unit: cost / 0.50, rounded to nearest $10
    function getOpt3PriceForModel(modelKey) { return roundTo10(MODELS[modelKey].cost / 0.50); }
    // Option 4 sell price per unit: cost * 2
    function getOpt4PriceForModel(modelKey) { return roundTo10(MODELS[modelKey].cost * 2); }
    // Maint fee per unit
    function getMaintFeeForModel(modelKey) { return MAINT_FEES[MODELS[modelKey].category]; }

    // ================================================================
    // AGGREGATED CALCULATION FUNCTIONS
    // ================================================================

    // --- Rental (Option 2 / Full-Service): uses customPrice if set, else grid[term] ---
    function calcRentalMonthlyTotal(term) {
      let total = 0;
      state.systems.forEach(s => {
        const rate = (s.customPrice !== null && s.customPrice >= 0) ? s.customPrice : MODELS[s.model].grid[term];
        total += rate * s.qty;
      });
      return total;
    }
    function calcRentalYr1(term) {
      return calcRentalMonthlyTotal(term) * 12;
    }
    function calcRentalAnnual(term) {
      return calcRentalMonthlyTotal(term) * 12;
    }
    function calcRentalCumulative(term, years) {
      // No install fee. Monthly payment × 12 each year.
      var annualCost = calcRentalMonthlyTotal(term) * 12;
      return annualCost * years;
    }

    // --- Time Purchase (Option 1): uses customPrice if set for effective monthly ---
    function calcTPEffMonthlyForSystem(sys, term) {
      if (sys.customPrice !== null && sys.customPrice >= 0) {
        // Apply the TP discount to the custom price instead of grid
        return sys.customPrice * DISCOUNTS[term];
      }
      const gridRate = MODELS[sys.model].grid[term];
      return gridRate * DISCOUNTS[term];
    }
    function calcTPMonthlyTotal(term) {
      let total = 0;
      state.systems.forEach(s => {
        total += calcTPEffMonthlyForSystem(s, term) * s.qty;
      });
      return total;
    }
    function calcTPTotalCommitment(term) {
      return calcTPMonthlyTotal(term) * term;
    }
    function calcTPYr1(term) {
      return calcTPMonthlyTotal(term) * 12;
    }
    function calcTPAnnual(term) {
      // During the term, no additional annual cost (it's all committed upfront).
      // After term, ongoing at effective monthly rate.
      return calcTPMonthlyTotal(term) * 12;
    }
    function calcTPCumulative(term, years) {
      // No install fee. TP commitment flat through the term.
      // On renewal, they purchase the same block again at the same price.
      var tpBlock = calcTPTotalCommitment(term);
      var termYears = term / 12;
      var blocks = Math.ceil(years / termYears);
      return tpBlock * blocks;
    }
    function calcTPSavings(term) {
      // Savings vs. paying the rate (custom or grid) monthly without discount
      let fullPrice = 0;
      let tpPrice = 0;
      state.systems.forEach(s => {
        const rate = (s.customPrice !== null && s.customPrice >= 0) ? s.customPrice : MODELS[s.model].grid[term];
        fullPrice += rate * term * s.qty;
        tpPrice += calcTPEffMonthlyForSystem(s, term) * term * s.qty;
      });
      return fullPrice - tpPrice;
    }

    // --- Option 3: Purchase + Maintenance (uses actual model cost, not customPrice) ---
    function calcOpt3PurchaseTotal() {
      let total = 0;
      state.systems.forEach(s => { total += getOpt3PriceForModel(s.model) * s.qty; });
      return total;
    }
    function calcOpt3MaintTotal() {
      let total = 0;
      state.systems.forEach(s => { total += getMaintFeeForModel(s.model) * s.qty; });
      return total;
    }
    function calcOpt3Yr1() {
      return calcOpt3PurchaseTotal() + getTotalInstallFee() + calcOpt3MaintTotal();
    }
    function calcOpt3Yr2Plus() {
      return calcOpt3MaintTotal();
    }
    function calcOpt3Cumulative(years) {
      // Year 1: purchase + install + maintenance. Year 2+: maintenance only.
      var upfront = calcOpt3PurchaseTotal() + getTotalInstallFee();
      var maint = calcOpt3MaintTotal();
      return upfront + maint * years;
    }

    // --- Option 4: Purchase + T&M (uses actual model cost, not customPrice) ---
    function calcOpt4PurchaseTotal() {
      let total = 0;
      state.systems.forEach(s => { total += getOpt4PriceForModel(s.model) * s.qty; });
      return total;
    }
    function calcOpt4ServiceCost() {
      return state.trips * TRIP_CHARGE * getTotalUnits();
    }
    function calcOpt4Yr1() {
      return calcOpt4PurchaseTotal() + getTotalInstallFee() + calcOpt4ServiceCost();
    }
    function calcOpt4Yr2Plus() {
      return calcOpt4ServiceCost();
    }
    function calcOpt4Cumulative(years) {
      // Year 1-5: purchase + install + service at selected trips rate.
      // Year 6+: service calls increase to 2.5 per system per year (aging equipment).
      var upfront = calcOpt4PurchaseTotal() + getTotalInstallFee();
      var totalUnits = getTotalUnits();
      var cumulative = upfront;
      for (var y = 1; y <= years; y++) {
        var tripsThisYear = (y <= 5) ? state.trips : 2.5;
        cumulative += tripsThisYear * TRIP_CHARGE * totalUnits;
      }
      return cumulative;
    }

    // Build cumulative data for a series over years
    function getCumulativeData(key, years) {
      const data = [];
      for (let y = 1; y <= years; y++) {
        switch (key) {
          case 'rental60': data.push(calcRentalCumulative(60, y)); break;
          case 'rental36': data.push(calcRentalCumulative(36, y)); break;
          case 'rental12': data.push(calcRentalCumulative(12, y)); break;
          case 'tp60':     data.push(calcTPCumulative(60, y)); break;
          case 'tp36':     data.push(calcTPCumulative(36, y)); break;
          case 'tp12':     data.push(calcTPCumulative(12, y)); break;
          case 'maint':    data.push(calcOpt3Cumulative(y)); break;
          case 'tm':       data.push(calcOpt4Cumulative(y)); break;
        }
      }
      return data;
    }

    // ================================================================
    // SYSTEMS LIST RENDERING
    // ================================================================
    function renderSystemsList() {
      const container = document.getElementById('systems-list-items');

      if (state.systems.length === 0) {
        container.innerHTML = '<div style="text-align:center;color:#94a3b8;font-size:14px;padding:20px;border:2px dashed #e2e8f0;border-radius:10px;background:#fff;">No systems added yet. Select a model and click "Add System" to begin.</div>';
        return;
      }

      const modelKeys = Object.keys(MODELS);
      function modelOpts(selected) {
        return modelKeys.map(k => '<option value="' + k + '"' + (k === selected ? ' selected' : '') + '>' + MODELS[k].label + '</option>').join('');
      }

      const thStyle = 'padding:12px 16px;background:#0c4a6e;color:#fff;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;text-align:center;border:1px solid #094067;';
      const tdStyle = 'padding:12px 16px;border:1px solid #cbd5e1;text-align:center;vertical-align:middle;font-size:14px;background:#fff;';
      const inputStyle = 'width:70px;padding:6px 8px;border:1px solid #cbd5e1;border-radius:4px;font-size:14px;font-weight:600;text-align:center;font-family:inherit;-moz-appearance:textfield;';
      const selectStyle = 'padding:6px 28px 6px 10px;border:1px solid #cbd5e1;border-radius:4px;font-size:13px;font-family:inherit;background:#fff;color:#1e293b;cursor:pointer;appearance:none;width:100%;max-width:200px;';

      let grandTotalMonthly = 0;
      let grandTotalInstall = 0;
      let grandTotalQty = 0;

      let rows = '';
      state.systems.forEach((sys, idx) => {
        const m = MODELS[sys.model];
        const gridRate60 = m.grid[60];
        const effectivePrice = (sys.customPrice !== null && sys.customPrice >= 0) ? sys.customPrice : gridRate60;
        const totalMonthly = effectivePrice * sys.qty;
        const installFee = INSTALL_FEE * sys.qty;
        grandTotalMonthly += totalMonthly;
        grandTotalInstall += installFee;
        grandTotalQty += sys.qty;

        const hasDiscount = sys.customPrice !== null && sys.customPrice >= 0 && sys.customPrice < gridRate60;
        let discountHtml = '';
        if (hasDiscount) {
          const pct = Math.round(((gridRate60 - sys.customPrice) / gridRate60) * 100);
          discountHtml = '<div style="margin-top:3px;"><span style="font-size:11px;color:#94a3b8;text-decoration:line-through;">Grid: ' + fmt(gridRate60) + '</span> <span style="font-size:10px;font-weight:700;color:#166534;background:#dcfce7;padding:1px 6px;border-radius:999px;">' + pct + '% off</span></div>';
        } else {
          discountHtml = '<div style="margin-top:3px;font-size:11px;color:#94a3b8;">Grid: ' + fmt(gridRate60) + '</div>';
        }

        rows += '<tr>'
          + '<td style="' + tdStyle + 'text-align:left;"><select style="' + selectStyle + '" data-idx="' + idx + '" class="js-model">' + modelOpts(sys.model) + '</select></td>'
          + '<td style="' + tdStyle + '"><input type="number" style="' + inputStyle + '" data-idx="' + idx + '" class="js-qty" value="' + sys.qty + '" min="1" max="99" /></td>'
          + '<td style="' + tdStyle + '"><input type="number" style="' + inputStyle + 'width:80px;" data-idx="' + idx + '" class="js-price" value="' + effectivePrice + '" min="0" step="1" />' + discountHtml + '</td>'
          + '<td style="' + tdStyle + 'font-weight:700;color:#0c4a6e;font-size:15px;">' + fmt(totalMonthly) + '</td>'
          + '<td style="' + tdStyle + 'background:none;border:none;width:40px;"><button type="button" data-idx="' + idx + '" class="js-remove" style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:20px;padding:4px 8px;border-radius:4px;">✕</button></td>'
          + '</tr>';
      });

      // Totals footer
      const ftStyle = 'padding:12px 16px;border:1px solid #094067;background:#0c4a6e;color:#fff;font-size:14px;font-weight:700;text-align:center;';
      rows += '<tr>'
        + '<td style="' + ftStyle + 'text-align:left;">Totals</td>'
        + '<td style="' + ftStyle + '">' + grandTotalQty + '</td>'
        + '<td style="' + ftStyle + '">' + fmt(grandTotalInstall) + ' install</td>'
        + '<td style="' + ftStyle + 'font-size:16px;">' + fmt(grandTotalMonthly) + '/mo</td>'
        + '<td style="background:none;border:none;"></td>'
        + '</tr>';

      container.innerHTML = '<table style="width:100%;border-collapse:collapse;border:2px solid #0c4a6e;">'
        + '<thead><tr>'
        + '<th style="' + thStyle + 'text-align:left;">Model</th>'
        + '<th style="' + thStyle + '">Quantity</th>'
        + '<th style="' + thStyle + '">System Monthly Payment</th>'
        + '<th style="' + thStyle + '">Total Monthly Payment</th>'
        + '<th style="background:#0c4a6e;border:1px solid #094067;width:40px;"></th>'
        + '</tr></thead>'
        + '<tbody>' + rows + '</tbody></table>';

      // Event handlers
      container.querySelectorAll('.js-remove').forEach(btn => {
        btn.addEventListener('click', function() {
          state.systems.splice(parseInt(this.dataset.idx), 1);
          renderSystemsList();
          updateAll();
        });
        btn.addEventListener('mouseenter', function() { this.style.color = '#dc2626'; });
        btn.addEventListener('mouseleave', function() { this.style.color = '#94a3b8'; });
      });

      container.querySelectorAll('.js-model').forEach(sel => {
        sel.addEventListener('change', function() {
          const idx = parseInt(this.dataset.idx);
          state.systems[idx].model = this.value;
          state.systems[idx].customPrice = null;
          renderSystemsList();
          updateAll();
        });
      });

      container.querySelectorAll('.js-qty').forEach(input => {
        input.addEventListener('change', function() {
          const idx = parseInt(this.dataset.idx);
          let val = parseInt(this.value);
          if (isNaN(val) || val < 1) val = 1;
          if (val > 99) val = 99;
          state.systems[idx].qty = val;
          this.value = val;
          renderSystemsList();
          updateAll();
        });
      });

      container.querySelectorAll('.js-price').forEach(input => {
        input.addEventListener('change', function() {
          const idx = parseInt(this.dataset.idx);
          let val = parseFloat(this.value);
          if (isNaN(val) || val < 0) val = 0;
          const gridRate = MODELS[state.systems[idx].model].grid[60];
          state.systems[idx].customPrice = (val === gridRate) ? null : val;
          renderSystemsList();
          updateAll();
        });
      });
    }

    // ================================================================
    // ADD SYSTEM HANDLER
    // ================================================================
    addSystemBtn.addEventListener('click', function() {
      const customVal = customPriceInput.value.trim();
      const customPrice = customVal !== '' ? parseFloat(customVal) : null;

      state.systems.push({
        model: state.addModel,
        qty: state.addQty,
        customPrice: (customPrice !== null && !isNaN(customPrice) && customPrice >= 0) ? customPrice : null
      });

      // Reset the add controls
      state.addQty = 1;
      qtyDisplay.value = 1;
      customPriceInput.value = '';

      renderSystemsList();
      updateAll();
    });

    // ================================================================
    // UPDATE OPTION CARDS
    // ================================================================
    function updateCards() {
      const noSystems = state.systems.length === 0;

      // Option 1 (Time Purchase card)
      const tpMonthly = calcTPMonthlyTotal(state.tpTerm);
      document.getElementById('opt2-monthly').innerHTML = fmt(Math.round(tpMonthly)) + '<span class="per"> effective monthly payment</span>';
      const tpTotal = calcTPTotalCommitment(state.tpTerm);
      document.getElementById('opt2-total').textContent = fmt(Math.round(tpTotal));
      // No install fee for Time Purchase
      var termLabels = { 60: '60-month', 36: '36-month', 12: '12-month' };
      document.getElementById('opt2-term-note').textContent = (termLabels[state.tpTerm] || state.tpTerm + '-month') + ' term commitment';

      const savingsEl = document.getElementById('opt2-savings');
      const savings = calcTPSavings(state.tpTerm);
      if (savings > 0 && !noSystems) {
        savingsEl.style.display = 'block';
        savingsEl.textContent = 'You save ' + fmt(Math.round(savings)) + ' vs. paying monthly over ' + state.tpTerm + ' months';
      } else {
        savingsEl.style.display = 'none';
      }

      // Option 2 (Rental card)
      const rentalMonthly = calcRentalMonthlyTotal(state.rentalTerm);
      document.getElementById('opt1-monthly').innerHTML = fmt(Math.round(rentalMonthly)) + '<span class="per"> monthly payment</span>';
      document.getElementById('opt1-total-monthly').textContent = fmt(Math.round(rentalMonthly));
      // No install fee for Rental

      // Option 3
      document.getElementById('opt3-purchase').textContent = fmt(calcOpt3PurchaseTotal());
      document.getElementById('opt3-install').textContent = fmt(getTotalInstallFee());
      document.getElementById('opt3-maint').textContent = fmt(calcOpt3MaintTotal());

      // Option 4
      document.getElementById('opt4-purchase').textContent = fmt(calcOpt4PurchaseTotal());
      document.getElementById('opt4-install').textContent = fmt(getTotalInstallFee());
      document.getElementById('trips-display').textContent = state.trips;
      document.getElementById('opt4-service-cost').textContent = fmt(Math.round(calcOpt4ServiceCost()));
    }

    // ================================================================
    // CHART
    // ================================================================
    let chart = null;

    function buildChart() {
      const ctx = document.getElementById('cost-chart').getContext('2d');
      const years = state.yearRange;
      const labels = [];
      for (let y = 1; y <= years; y++) labels.push('Year ' + y);

      const datasets = SERIES_DEFS.filter(s => seriesVisible[s.key]).map(s => ({
        label: s.label,
        data: getCumulativeData(s.key, years),
        borderColor: s.color,
        backgroundColor: s.color + '18',
        borderWidth: 2.5,
        borderDash: s.dash,
        pointRadius: 4,
        pointHoverRadius: 6,
        pointBackgroundColor: s.color,
        tension: 0.1,
        fill: false
      }));

      if (chart) chart.destroy();

      chart = new Chart(ctx, {
        type: 'line',
        data: { labels, datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              backgroundColor: '#0f172a',
              titleFont: { family: 'Plus Jakarta Sans', size: 13, weight: '600' },
              bodyFont: { family: 'Plus Jakarta Sans', size: 12 },
              padding: 12,
              cornerRadius: 8,
              callbacks: {
                label: function(context) {
                  return context.dataset.label + ': ' + fmt(Math.round(context.parsed.y));
                }
              }
            }
          },
          scales: {
            x: {
              grid: { display: false },
              ticks: {
                font: { family: 'Plus Jakarta Sans', size: 12 },
                color: '#64748b'
              }
            },
            y: {
              grid: { color: '#f1f5f9' },
              ticks: {
                font: { family: 'Plus Jakarta Sans', size: 12 },
                color: '#64748b',
                callback: function(value) { return fmtK(value); }
              },
              beginAtZero: true
            }
          }
        }
      });
    }

    // ================================================================
    // SERIES TOGGLE PILLS
    // ================================================================
    function renderSeriesTogggles() {
      const container = document.getElementById('series-toggles');
      container.innerHTML = '';
      SERIES_DEFS.forEach(s => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'series-toggle' + (seriesVisible[s.key] ? ' active' : '');
        btn.style.color = seriesVisible[s.key] ? s.color : '#94a3b8';
        btn.innerHTML = '<span class="dot" style="background:' + s.color + ';opacity:' + (seriesVisible[s.key] ? '1' : '0.3') + '"></span>' + s.label;
        btn.addEventListener('click', function() {
          seriesVisible[s.key] = !seriesVisible[s.key];
          renderSeriesTogggles();
          buildChart();
          updateSummaryTable();
        });
        container.appendChild(btn);
      });
    }

    // ================================================================
    // SUMMARY TABLE
    // ================================================================
    function updateSummaryTable() {
      const tbody = document.getElementById('summary-tbody');
      tbody.innerHTML = '';

      const rows = SERIES_DEFS.filter(s => seriesVisible[s.key]).map(s => {
        let yr1, annual, cum5, cum10;
        const data5 = getCumulativeData(s.key, 5);
        const data10 = getCumulativeData(s.key, 10);
        yr1 = data5[0];
        cum5 = data5[4];
        cum10 = data10[9];

        // Annual yr2+
        if (s.key.startsWith('rental')) {
          const term = parseInt(s.key.replace('rental', ''));
          annual = calcRentalAnnual(term);
        } else if (s.key.startsWith('tp')) {
          const term = parseInt(s.key.replace('tp', ''));
          annual = calcTPAnnual(term);
        } else if (s.key === 'maint') {
          annual = calcOpt3Yr2Plus();
        } else {
          annual = calcOpt4Yr2Plus();
        }

        return { label: s.label, color: s.color, yr1, annual, cum5, cum10 };
      });

      rows.forEach(r => {
        const tr = document.createElement('tr');
        const vals = [
          { html: '<span class="option-dot" style="background:' + r.color + '"></span>' + r.label, highlight: false },
          { html: fmt(Math.round(r.yr1)), highlight: false },
          { html: fmt(Math.round(r.annual)), highlight: false },
          { html: fmt(Math.round(r.cum5)), highlight: state.yearRange === 5 },
          { html: fmt(Math.round(r.cum10)), highlight: state.yearRange === 10 }
        ];
        vals.forEach((v, i) => {
          const td = document.createElement('td');
          td.innerHTML = v.html;
          if (v.highlight) td.classList.add('col-highlight');
          tr.appendChild(td);
        });
        tbody.appendChild(tr);
      });

      // Update table header highlights
      const ths = document.querySelectorAll('.summary-table th');
      ths.forEach((th, i) => {
        th.classList.remove('col-highlight');
        if ((state.yearRange === 5 && i === 3) || (state.yearRange === 10 && i === 4)) {
          th.classList.add('col-highlight');
        }
      });
    }

    // ================================================================
    // YEAR TOGGLE
    // ================================================================
    document.getElementById('year-toggle').addEventListener('click', function(e) {
      const btn = e.target.closest('button');
      if (!btn) return;
      const years = parseInt(btn.dataset.years);
      state.yearRange = years;
      document.querySelectorAll('#year-toggle button').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      buildChart();
      updateSummaryTable();
    });

    // ================================================================
    // TERM PILL HANDLERS
    // ================================================================
    document.getElementById('term-pills-1').addEventListener('click', function(e) {
      const pill = e.target.closest('.term-pill');
      if (!pill) return;
      state.rentalTerm = parseInt(pill.dataset.term);
      this.querySelectorAll('.term-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      state.lastViewedOption = 'Option 2 — Full-Service Rental';
      updateAll();
    });

    document.getElementById('term-pills-2').addEventListener('click', function(e) {
      const pill = e.target.closest('.term-pill');
      if (!pill) return;
      state.tpTerm = parseInt(pill.dataset.term);
      this.querySelectorAll('.term-pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      state.lastViewedOption = 'Option 1 — Time Purchase';
      updateAll();
    });

    // ================================================================
    // MODEL + QTY HANDLERS (for the add-system builder)
    // ================================================================
    modelSelect.addEventListener('change', function() {
      state.addModel = this.value;
    });

    qtyMinus.addEventListener('click', function() {
      if (state.addQty > 1) { state.addQty--; qtyDisplay.value = state.addQty; }
    });
    qtyPlus.addEventListener('click', function() {
      if (state.addQty < 99) { state.addQty++; qtyDisplay.value = state.addQty; }
    });
    qtyDisplay.addEventListener('change', function() {
      let val = parseInt(this.value);
      if (isNaN(val) || val < 1) val = 1;
      if (val > 99) val = 99;
      state.addQty = val;
      this.value = val;
    });

    tripsSlider.addEventListener('input', function() {
      state.trips = parseFloat(this.value);
      state.lastViewedOption = 'Option 4 — Purchase + Time & Materials';
      updateAll();
    });

    // ================================================================
    // MASTER UPDATE
    // ================================================================
    function updateAll() {
      updateCards();
      buildChart();
      updateSummaryTable();
    }

    // Lead form removed — no submit handler needed

    // Track which option card the user last interacted with via scroll visibility
    const cardObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          const card = entry.target;
          if (card.classList.contains('card-option1')) state.lastViewedOption = 'Option 2 — Full-Service Rental';
          else if (card.classList.contains('card-option2')) state.lastViewedOption = 'Option 1 — Time Purchase';
          else if (card.classList.contains('card-option3')) state.lastViewedOption = 'Option 3 — Purchase + Annual Maintenance';
          else if (card.classList.contains('card-option4')) state.lastViewedOption = 'Option 4 — Purchase + Time & Materials';
        }
      });
    }, { threshold: 0.5 });

    document.querySelectorAll('.option-card').forEach(function(card) {
      cardObserver.observe(card);
    });

    // ================================================================
    // INIT
    // ================================================================
    renderSeriesTogggles();
    renderSystemsList();
    updateAll();
  </script>


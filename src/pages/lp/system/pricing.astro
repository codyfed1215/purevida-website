      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 4px;
    }
    .modal-submit:hover { background: #009bb5; }
    .modal-promo {
      margin-top: 16px;
      text-align: center;

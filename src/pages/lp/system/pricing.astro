<script>
  // Category toggle (Water vs Ice & Water)
  const categoryBtns = document.querySelectorAll('.category-btn');
  const categoryPanels = document.querySelectorAll('.category-panel');

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      categoryBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      categoryPanels.forEach(panel => panel.classList.remove('active'));
      document.getElementById(`category-${category}`)?.classList.add('active');
    });
  });

  // Product tab switching (within each category)
  document.querySelectorAll('.category-panel').forEach(categoryPanel => {
    const tabs = categoryPanel.querySelectorAll('.product-tab');
    const panels = categoryPanel.querySelectorAll('.product-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const productId = tab.getAttribute('data-product');

        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');

        panels.forEach(panel => panel.classList.remove('active'));
        document.getElementById(`product-${productId}`)?.classList.add('active');
      });
    });
  });

  // Pricing sliders
  // Steps: 60mo = 0 increments, 36mo = 2 increments, 12mo = 4 increments
  const termIncrements = [0, 2, 4];

  document.querySelectorAll('.term-slider').forEach(slider => {
    const controls = slider.closest('.pricing-slider-controls');
    const basePrice = parseInt(controls.dataset.base);
    const increment = parseInt(controls.dataset.increment);
    const panel = slider.closest('.product-panel');
    const priceDisplay = panel.querySelector('.monthly-price');

    slider.addEventListener('input', () => {
      const stepIndex = parseInt(slider.value);
      const price = basePrice + (termIncrements[stepIndex] * increment);
      priceDisplay.textContent = `$${price}/mo`;
    });
  });

  // Specs modal
  const specsModal = document.getElementById('specs-modal');
  const specsTitle = document.getElementById('specs-modal-title');
  const specsList = document.getElementById('specs-modal-list');
  const specsClose = document.getElementById('specs-modal-close');
  const specsBackdrop = document.getElementById('specs-modal-backdrop');

  document.querySelectorAll('.view-specs-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const specs = JSON.parse(btn.dataset.specs);
      const name = btn.dataset.name;
      specsTitle.textContent = `${name} Specifications`;
      specsList.innerHTML = specs.map(s => `<li><strong>${s.label}:</strong> ${s.value}</li>`).join('');
      specsModal.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeSpecsModal() {
    specsModal.classList.remove('open');
    document.body.style.overflow = '';
  }
  specsClose?.addEventListener('click', closeSpecsModal);
  specsBackdrop?.addEventListener('click', closeSpecsModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && specsModal.classList.contains('open')) closeSpecsModal();
  });

  // Menu dropdown toggle
  const menuToggle = document.getElementById('menu-toggle');
  const navDropdown = document.getElementById('nav-dropdown');

  menuToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    navDropdown?.classList.toggle('open');
  });

  // Close dropdown when clicking a link or outside
  navDropdown?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => navDropdown.classList.remove('open'));
  });
  document.addEventListener('click', () => navDropdown?.classList.remove('open'));
</script>


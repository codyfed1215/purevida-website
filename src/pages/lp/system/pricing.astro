    .card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; color: var(--navy-dark); }
    .card p { font-size: 0.95rem; color: var(--gray-text); line-height: 1.5; }

    /* -- SOLUTION -- */
    .solution { background: var(--bg-light); padding: 80px 0; }

    }

    .nav {
      background: #ffffff;
      border-bottom: 1px solid #E8EEF3;
      padding: 14px 0;
    }

    .container {
      max-width: 1140px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 800;
      font-size: 1.5rem;
      color: #12263A;
      text-decoration: none;
    }

    .nav-brand .pure { color: #0ea5e9; }
    .nav-brand .vida { color: #0c4a6e; }

    .nav-phone {
      color: #0ea5e9;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
    }

    .nav-phone:hover {
      text-decoration: underline;
    }

    .main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 80px 24px;
      background: linear-gradient(180deg, #f0f9ff 0%, #e0f2fe 40%, #f0f9ff 100%);
    }

    .thank-you-card {
      background: #ffffff;
      border-radius: 16px;
      padding: 60px 48px;
      max-width: 640px;
      width: 100%;
      text-align: center;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
    }

    .checkmark {
      width: 72px;
      height: 72px;
      background: #0ea5e9;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 24px;
    }

    .checkmark svg {
      width: 36px;
      height: 36px;
      color: #ffffff;
    }

    .thank-you-card h1 {
      font-size: 2.25rem;
      font-weight: 800;
      color: #0c4a6e;
      margin-bottom: 16px;
      line-height: 1.2;
    }

    .thank-you-card p {
      font-size: 1.15rem;
      color: #5A6A7A;
      margin-bottom: 12px;
      line-height: 1.6;
    }

    .thank-you-card p.highlight {
      font-size: 1.25rem;
      font-weight: 700;
      color: #0ea5e9;
      margin-top: 8px;
      margin-bottom: 32px;
    }

    .btn-home {
      display: inline-block;
      background: #0ea5e9;
      color: #ffffff;
      padding: 16px 36px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1.05rem;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
    }

    .btn-home:hover {
      background: #0284c7;
      transform: translateY(-1px);
    }

    .contact-email {
      margin-top: 20px;
      font-size: 1rem;
    }

    .contact-email a {
      color: #0ea5e9;
      text-decoration: none;
      font-weight: 600;
    }

    .contact-email a:hover {
      text-decoration: underline;
    }

    footer {
      background: #12263A;
      padding: 24px 0;
      text-align: center;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.85rem;
    }

    footer a {
      color: #0ea5e9;
      text-decoration: none;
    }

    footer a:hover {
      text-decoration: underline;
    }

    @media (max-width: 768px) {
      .main { padding: 48px 16px; }
      .thank-you-card { padding: 40px 24px; }
      .thank-you-card h1 { font-size: 1.75rem; }
      .thank-you-card p { font-size: 1rem; }
      .thank-you-card p.highlight { font-size: 1.1rem; }

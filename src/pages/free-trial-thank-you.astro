---
// Thank You Page — Google Ads conversion tracking fires on this page load
// Route: /free-trial-thank-you
import '../styles/global.css'
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Thank You | PureVida Water Technologies</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />

  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-RT2GYZLRSW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-RT2GYZLRSW');
  </script>

  <!-- Google Tag Manager -->
  <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','GTM-NHL3XGV2');</script>
</head>

<body class="bg-white text-gray-900 antialiased">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NHL3XGV2" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- NAV -->
  <nav class="bg-white border-b border-gray-200 px-4 sm:px-6 py-3.5 flex items-center justify-between">
    <a href="https://purevidawater.com" class="flex items-center gap-2.5">
      <img src="/images/water-drop-logo.png" alt="PureVida Water" class="h-9 w-auto" />
      <span class="text-lg font-bold tracking-tight">
        <span class="text-sky-500">Pure</span><span class="text-sky-800">Vida</span>
      </span>
    </a>
    <a href="tel:+18885340117" class="flex items-center gap-1.5 text-sky-500 hover:text-sky-600 transition-colors font-semibold text-sm sm:text-base">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      (888) 534-0117
    </a>
  </nav>

  <!-- MAIN -->
  <main class="max-w-xl mx-auto px-4 py-20 text-center min-h-[70vh] flex flex-col items-center justify-center">
    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>
    <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-3">You're All Set!</h1>
    <p class="text-lg text-gray-600">Thank you for requesting your free 7-day trial.</p>
    <p class="text-lg text-gray-600">Our team will reach out shortly to schedule your free installation.</p>

    <div class="mt-10 bg-gray-50 border border-gray-200 rounded-2xl p-6 sm:p-8 text-left w-full">
      <h3 class="text-base font-bold text-gray-900 mb-4">What happens next?</h3>
      <ol class="space-y-2 text-sm text-gray-600 list-decimal list-inside leading-relaxed">
        <li>A PureVida specialist will call to confirm your setup details</li>
        <li>We'll schedule a convenient installation time</li>
        <li>Our tech installs your system — typically under 30 minutes</li>
        <li>Enjoy unlimited purified water, on us for 30 days</li>
      </ol>
    </div>

    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href="tel:+18885340117" class="inline-block bg-sky-500 hover:bg-sky-600 text-white font-semibold text-sm px-6 py-3.5 rounded-xl transition-colors shadow-lg shadow-sky-500/25">Call Us Now: (888) 534-0117</a>
      <a href="https://purevidawater.com" class="inline-block border-2 border-sky-500 hover:bg-sky-50 text-sky-500 font-semibold text-sm px-6 py-3.5 rounded-xl transition-colors">Visit Our Website</a>
    </div>
  </main>

  <!-- FOOTER -->
  <footer class="bg-gray-900 py-6 px-4 text-center">
    <p class="text-gray-500 text-xs mb-1">&copy; 2026 PureVida Water Technologies. All rights reserved.</p>
    <a href="https://purevidawater.com" class="text-sky-500 hover:text-sky-400 text-xs transition-colors">Return to Main Website</a>
  </footer>

  <!-- Fire conversion event on page load -->
  <script>
    if (typeof gtag === 'function') {
      gtag('event', 'conversion', {
        send_to: 'G-RT2GYZLRSW',
        event_category: 'form',
        event_label: 'free_trial_complete',
      });
    }
  </script>
</body>
</html>

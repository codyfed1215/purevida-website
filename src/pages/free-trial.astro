  </div>

  <!-- ============ BENEFITS ============ -->
  <section class="py-16 px-4 sm:px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 text-center">Why Businesses Switch to PureVida</h2>

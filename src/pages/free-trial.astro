                <input type="text" id="lname" name="last_name" placeholder="Smith" required class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-sm transition" />
              </div>
            </div>
            <div>
              <label for="company" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Company Name</label>
              <input type="text" id="company" name="company" placeholder="Acme Corp" required class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-sm transition" />
            </div>
            <div>
              <label for="email" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Work Email</label>
              <input type="email" id="email" name="email" placeholder="jane@acmecorp.com" required class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-sm transition" />
            </div>
            <div>
              <label for="phone" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="(214) 555-0000" required class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-sm transition" />
            </div>
            <div>
              <label for="city" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">City / Service Area</label>
              <select id="city" name="city" required class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-gray-50 focus:bg-white focus:ring-2 focus:ring-sky-500 focus:border-sky-500 outline-none text-sm transition appearance-none">
                <option value="">Select your area...</option>
                <option value="Dallas">Dallas</option>
                <option value="Fort Worth">Fort Worth</option>
                <option value="Plano / Frisco">Plano / Frisco</option>
                <option value="Irving / Arlington">Irving / Arlington</option>
                <option value="Austin">Austin</option>
                <option value="San Antonio">San Antonio</option>
                <option value="Other DFW Area">Other DFW Area</option>
              </select>
            </div>
            <button type="submit" id="submit-btn" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-semibold py-4 px-6 rounded-xl transition-colors text-lg cursor-pointer shadow-lg shadow-sky-500/25 disabled:opacity-50 disabled:cursor-not-allowed">
              Claim My Free 7-Day Trial &rarr;

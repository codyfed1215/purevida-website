        <span class="text-sky-500">Pure</span><span class="text-sky-800">Vida</span>
      </span>
    </a>
    <a href="tel:+18885340117" class="flex items-center gap-1.5 text-sky-500 hover:text-sky-600 transition-colors font-semibold text-sm sm:text-base">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      (888) 534-0117
    </a>
  </nav>

  <!-- ============ HERO + FORM ============ -->
  <section class="relative bg-gradient-to-br from-sky-50 to-cyan-50 overflow-hidden">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-20 left-10 w-72 h-72 bg-sky-200 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 right-10 w-96 h-96 bg-cyan-200 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Copy -->
        <div>
          <span class="inline-block bg-sky-500 text-white text-xs font-bold uppercase tracking-wider px-4 py-1.5 rounded-full mb-5">For Texas Businesses</span>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight">
            Ditch the Jugs.<br/>Get <span class="text-sky-500">Bottle-less Water</span><br/>Free for 7 Days.
          </h1>
          <p class="mt-5 text-lg text-gray-600 leading-relaxed">
            PureVida installs, maintains, and services your office water system —
            unlimited filtered water, ice, and coffee at a fraction of bottled delivery costs.
            No jugs. No hassle.
          </p>
          <ul class="mt-6 space-y-3">
            <li class="flex items-center gap-3 text-gray-700">
              <span class="flex items-center justify-center w-5 h-5 bg-sky-500 text-white rounded-full shrink-0">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </span>
              Quick & easy installation — we handle everything
            </li>
            <li class="flex items-center gap-3 text-gray-700">
              <span class="flex items-center justify-center w-5 h-5 bg-sky-500 text-white rounded-full shrink-0">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </span>
              Save 30–80% vs. bottled water delivery
            </li>
            <li class="flex items-center gap-3 text-gray-700">
              <span class="flex items-center justify-center w-5 h-5 bg-sky-500 text-white rounded-full shrink-0">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </span>
              Serving DFW, Austin & San Antonio
            </li>
            <li class="flex items-center gap-3 text-gray-700">
              <span class="flex items-center justify-center w-5 h-5 bg-sky-500 text-white rounded-full shrink-0">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
              </span>
              1,100+ Texas businesses already switched
            </li>
          </ul>
        </div>

        <!-- Right: Form Card -->
        <div class="bg-white rounded-2xl shadow-xl shadow-gray-900/10 p-8 sm:p-10">
          <h2 class="text-2xl font-bold text-gray-900 text-center mb-1">Start Your Free Trial</h2>
          <p class="text-sm text-gray-500 text-center mb-6">We'll contact you shortly to schedule your <strong class="text-sky-500">quick & easy installation</strong>.</p>
          <form id="trial-form" class="space-y-4">
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="fname" class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">First Name</label>

---
// Google Ads Landing Page: Free 30-Day Trial
// Standalone page — no shared Layout (no nav links to distract)
// Route: /free-trial
// Form submits to ingest-lead, then redirects to /free-trial-thank-you for conversion tracking
import '../styles/global.css'

const SUPABASE_URL = 'https://tpqipscwaovlujxolfal.supabase.co';
---

<html lang="en">
<head>

      <span class="text-white text-sm font-semibold opacity-70">UT Austin</span>
      <span class="text-white text-sm font-semibold opacity-70">Dallas Market Center</span>
      <span class="text-white text-sm font-semibold opacity-70">Caliber</span>
      <span class="text-white text-sm font-semibold opacity-70">Matheson</span>

    </div>
  </section>

  <!-- ============ SOCIAL PROOF BAR ============ -->
  <div class="bg-gray-900 py-5 px-4">
    <p class="text-center text-xs font-semibold uppercase tracking-widest text-sky-300 mb-3">Trusted by 1,100+ Texas businesses including</p>

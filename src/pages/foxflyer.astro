---
// Redirect: /foxflyer → /lp/flyer with foxflyer UTMs + promo passthrough
---
<html>
<head>
  <link rel="canonical" href="/lp/flyer" />
  <script is:inline>
    var params = new URLSearchParams(window.location.search);
    var promo = params.get('promo') || '';
    var dest = '/lp/flyer?source=foxflyer&utm_source=foxflyer&utm_medium=flyer&utm_campaign=foxflyer_drop';
    if (promo) dest += '&promo=' + encodeURIComponent(promo);
    window.location.replace(dest);
  </script>
  <meta http-equiv="refresh" content="2;url=/lp/flyer?source=foxflyer&utm_source=foxflyer&utm_medium=flyer&utm_campaign=foxflyer_drop" />
</head>
<body>
  <p>Redirecting...</p>
</body>
</html>

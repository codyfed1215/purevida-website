---
// Landing Page: Southern Methodist University (SMU)
// Standalone page — no shared Layout
// Route: /landing-pages/smu
// Combines TWU hero/systems style + pricing page content + major accounts pricing tool
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>PureVida Water | A Better Hydration Solution for Southern Methodist University</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cyan: #00B8D4;
      --cyan-light: #00D4F5;
      --navy: #1A3553;
      --navy-dark: #12263A;
      --bg-light: #EBF2F8;
      --bg-section: #F4F8FB;
      --white: #ffffff;
      --gray-text: #5A6A7A;
      --red-cta: #E84A3D;
      --red-cta-hover: #D43A2E;
      --card-shadow: 0 2px 12px rgba(0,0,0,0.06);
      --card-radius: 12px;
      /* SMU Colors */
      --smu-red: #CC0035;
      --smu-blue: #354CA1;
      /* Major accounts option colors */
      --option1: #0ea5e9;
      --option2: #14A38B;
      --option3: #D97706;
      --option4: #DC2626;
      --bg-option1: #f0f9ff;
      --bg-option2: #ECFDF5;
      --bg-option3: #FFFBEB;
      --bg-option4: #FEF2F2;
      --border-option1: #BFDBFE;
      --border-option2: #A7F3D0;
      --border-option3: #FDE68A;
      --border-option4: #FECACA;
      --blue-accent: #0ea5e9;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: var(--navy);
      background: var(--white);
      line-height: 1.6;
    }

    /* -- Accent bar -- */
    .accent-bar {
      height: 5px;
      background: linear-gradient(90deg, var(--cyan), var(--cyan-light));
    }

    /* -- Utility -- */
    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
    .section-title {
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--navy-dark);
      margin-bottom: 8px;
      text-align: center;
    }
    .section-subtitle {
      font-size: 1.1rem;
      color: var(--gray-text);
      margin-bottom: 48px;
    }
    .underline-accent {
      width: 60px; height: 4px;
      background: var(--cyan);
      border-radius: 2px;
      margin-bottom: 20px;
      margin-left: auto;
      margin-right: auto;
    }
    .text-center { text-align: center; }
    .underline-center { margin-left: auto; margin-right: auto; }

    /* -- NAV -- */
    .nav {
      background: var(--white);
      border-bottom: 1px solid #E8EEF3;
      padding: 14px 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 800;
      font-size: 1.15rem;
      color: var(--navy-dark);
      text-decoration: none;
    }
    .nav-logo {
      height: 52px;
      width: auto;
      object-fit: contain;
    }
    .nav-links { display: flex; gap: 28px; align-items: center; }
    .nav-links a {
      text-decoration: none;
      color: var(--gray-text);
      font-weight: 500;
      font-size: 0.92rem;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--cyan); }
    .nav-cta {
      background: var(--red-cta) !important;
      color: var(--white) !important;
      padding: 10px 22px;
      border-radius: 50px;
      font-weight: 600 !important;
    }
    .nav-cta:hover { background: var(--red-cta-hover) !important; }

    .mobile-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
    }
    .mobile-toggle span {
      display: block;
      width: 24px;
      height: 2px;
      background: var(--navy);
      margin: 5px 0;
      border-radius: 2px;
      transition: 0.3s;
    }

    /* -- HERO -- */
    .hero {
      background: var(--bg-light);
      padding: 48px 0 64px;
      text-align: center;
      position: relative;
    }
    .hero-logos {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 20px;
      margin-bottom: 48px;
      flex-wrap: wrap;
    }
    .hero-logo-img {
      max-height: 80px;
      width: auto;
      object-fit: contain;
    }
    .hero-logo-img.smu-logo { max-height: 140px; border-radius: 8px; }
    .hero-logo-img.purevida-logo { max-height: 90px; }
    .hero-plus { font-size: 1.5rem; color: var(--cyan); font-weight: 300; }

    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.25rem);
      font-weight: 800;
      color: var(--navy-dark);
      line-height: 1.15;
      margin-bottom: 16px;
    }
    .hero p.tagline {
      font-size: 1.2rem;
      color: var(--gray-text);
      margin-bottom: 32px;
    }
    .hero-contact {
      font-size: 0.95rem;
      color: var(--cyan);
    }
    .hero-contact a { color: var(--cyan); text-decoration: none; font-weight: 600; }
    .hero-contact a:hover { text-decoration: underline; }

    .btn-primary {
      display: inline-block;
      background: var(--red-cta);
      color: var(--white);
      padding: 16px 36px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1.05rem;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      border: none;
      cursor: pointer;
    }
    .btn-primary:hover { background: var(--red-cta-hover); transform: translateY(-1px); }

    .btn-outline {
      display: inline-block;
      border: 2px solid var(--cyan);
      color: var(--cyan);
      padding: 14px 32px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .btn-outline:hover { background: var(--cyan); color: var(--white); }

    .hero-buttons { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 32px; }

    /* -- PROBLEMS (pricing page style) -- */
    .problems { background: var(--bg-light); padding: 80px 0; }
    .problems-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      max-width: 900px;
      margin: 0 auto;
    }
    .problem-card {
      background: var(--white);
      border-radius: var(--card-radius);
      padding: 32px 28px;
      box-shadow: var(--card-shadow);
    }
    .problem-card-title {
      font-size: 1.4rem;
      font-weight: 800;
      color: var(--navy-dark);
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 3px solid var(--cyan);
    }
    .problem-list {
      list-style: none;
    }
    .problem-list li {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      padding: 10px 0;
      border-bottom: 1px solid #EEF2F6;
    }
    .problem-list li:last-child { border-bottom: none; }
    .problem-bullet {
      min-width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--red-cta);
      margin-top: 6px;
    }
    .problem-list strong {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--navy-dark);
      display: block;
      margin-bottom: 2px;
    }
    .problem-list p {
      font-size: 0.88rem;
      color: var(--gray-text);
      line-height: 1.4;
      margin: 0;
    }

    /* -- SOLUTION -- */
    .solution { background: var(--bg-light); padding: 80px 0; }
    .card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }
    .card {
      background: var(--white);
      border-radius: var(--card-radius);
      padding: 32px 28px;
      box-shadow: var(--card-shadow);
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(0,0,0,0.1); }
    .card-icon {
      width: 48px; height: 48px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.25rem; font-weight: 700;
      color: var(--white);
      margin-bottom: 16px;
    }
    .card-icon.solution-icon { background: var(--cyan); }
    .card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; color: var(--navy-dark); }
    .card p { font-size: 0.95rem; color: var(--gray-text); line-height: 1.5; }

    /* -- VIDEO -- */
    .video { background: var(--white); padding: 80px 0; }
    .video-wrapper {
      position: relative;
      padding-bottom: 56.25%;
      height: 0;
      overflow: hidden;
      border-radius: var(--card-radius);
      box-shadow: 0 4px 24px rgba(0,0,0,0.1);
      max-width: 800px;
      margin: 0 auto;
    }
    .video-wrapper iframe {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      border: 0;
    }

    /* -- FILTRATION -- */
    .filtration { background: #0ea5e9; padding: 64px 0; }
    .filtration .section-title { color: var(--white); }
    .filtration .section-subtitle { color: rgba(255,255,255,0.8); }
    .filtration .underline-accent { background: rgba(255,255,255,0.5); }
    .filtration-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .filtration-card {
      position: relative;
      background: rgba(255,255,255,0.1);
      border: 2px solid rgba(255,255,255,0.4);
      border-radius: 16px;
      padding: 16px 16px 20px;
      color: var(--white);
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .filtration-card img {
      width: 56px;
      height: 56px;
      object-fit: contain;
      margin-bottom: 12px;
    }
    .filtration-card h3 {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 4px;
      line-height: 1.3;
    }
    .filtration-card .reduces-label {
      font-size: 0.75rem;
      font-weight: 600;
      margin-top: 8px;
    }
    .filtration-card ul {
      list-style: none;
      font-size: 0.75rem;
      color: rgba(255,255,255,0.8);
      margin-top: 4px;
      text-align: left;
    }
    .filtration-card ul li::before {
      content: "\2022 ";
    }
    .filtration-card .taste-text {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.8);
      margin-top: 8px;
    }
    .step-badge {
      position: absolute;
      bottom: -12px;
      left: -12px;
      width: 32px;
      height: 32px;
      background: #38bdf8;
      border: 2px solid rgba(255,255,255,0.6);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--white);
      font-weight: 700;
      font-size: 0.85rem;
    }
    .filtration-row-gap {
      margin-top: 24px;
    }

    /* -- TRUSTED -- */
    .trusted { background: var(--bg-light); padding: 80px 0; }
    .trust-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }
    .trust-card {
      background: var(--white);
      border-radius: var(--card-radius);
      padding: 28px;
      box-shadow: var(--card-shadow);
      display: flex;
      align-items: center;
      gap: 18px;
      transition: transform 0.2s;
    }
    .trust-card:hover { transform: translateY(-2px); }
    .trust-icon {
      min-width: 52px; height: 52px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-weight: 800; font-size: 0.85rem; color: var(--white);
    }
    .trust-icon.burnt-orange { background: #BF5700; }
    .trust-icon.teal { background: var(--cyan); }
    .trust-card h4 { font-size: 1rem; font-weight: 700; color: var(--navy-dark); }
    .trust-card p { font-size: 0.88rem; color: var(--gray-text); }
    .trust-highlight {
      text-align: center;
      margin-top: 48px;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--cyan);
    }

    /* Reviews */
    .reviews-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      max-width: 900px;
      margin: 36px auto 0;
    }
    .review-card {
      background: var(--white);
      border-radius: var(--card-radius);
      padding: 28px 32px;
      box-shadow: var(--card-shadow);
      text-align: center;
    }
    .review-stars {
      font-size: 1.5rem;
      color: #f59e0b;
      margin-bottom: 12px;
      letter-spacing: 2px;
    }
    .review-card blockquote {
      font-size: 0.95rem;
      color: var(--gray-text);
      line-height: 1.6;
      font-style: italic;
      margin: 0;
    }
    .review-source {
      margin-top: 12px;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--navy-dark);
    }

    /* -- SYSTEMS (TWU style tabs) -- */
    .systems { background: var(--white); padding: 80px 0; }
    .systems-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .system-card {
      background: var(--white);
      border-radius: var(--card-radius);
      border: 1px solid #E0E8EF;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .system-card:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(0,0,0,0.1); }
    .system-card-header {
      padding: 24px 28px 16px;
      text-align: center;
      border-bottom: 1px solid #EEF2F6;
    }
    .consumption-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--cyan);
      margin-bottom: 8px;
    }
    .system-card-header h3 {
      font-size: 1.75rem;
      font-weight: 800;
      color: var(--navy-dark);
    }
    .system-card-header .model-tagline {
      font-style: italic;
      color: var(--gray-text);
      font-size: 0.95rem;
      margin-top: 4px;
    }
    .system-card {
      display: flex;
      flex-direction: column;
    }
    .system-card-img {
      display: flex;
      justify-content: center;
      align-items: flex-end;
      gap: 12px;
      padding: 16px 16px 0;
      height: 200px;
    }
    .system-card-img img {
      max-height: 180px;
      object-fit: contain;
      filter: drop-shadow(0 4px 12px rgba(0,0,0,0.1));
    }
    .system-card-body {
      padding: 24px 28px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .system-card-body .meta-spacer {
      flex: 1;
    }
    .system-card-body .card-bottom {
      margin-top: auto;
    }
    .system-card-body .meta-item {
      margin-bottom: 6px;
      font-size: 0.92rem;
      color: var(--gray-text);
    }
    .meta-item strong { color: var(--cyan); font-weight: 700; }
    .system-card-body h4 {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--navy-dark);
      margin: 20px 0 10px;
      padding-top: 16px;
      border-top: 1px solid #EEF2F6;
    }
    .spec-line {
      font-size: 0.85rem;
      color: var(--gray-text);
      margin-bottom: 3px;
    }
    .spec-line strong { color: var(--navy); font-weight: 600; }
    .system-card-accent {
      height: 4px;
      background: linear-gradient(90deg, var(--cyan), var(--cyan-light));
    }
    .systems-note {
      text-align: center;
      font-style: italic;
      color: var(--gray-text);
      margin-top: 36px;
      font-size: 0.95rem;
    }

    /* -- TABS -- */
    .tab-container { text-align: center; margin-bottom: 40px; }
    .tab-btn {
      background: none;
      border: 2px solid #D8E2EA;
      color: var(--gray-text);
      padding: 12px 28px;
      border-radius: 50px;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      margin: 0 6px;
      transition: all 0.2s;
      font-family: inherit;
    }
    .tab-btn.active, .tab-btn:hover {
      border-color: var(--cyan);
      color: var(--cyan);
      background: rgba(0, 184, 212, 0.05);
    }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* Card Pricing Table */
    .card-pricing {
      margin-top: 16px;
      padding-top: 16px;
      border-top: 1px solid #EEF2F6;
    }
    .pricing-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.82rem;
    }
    .pricing-table thead th {
      padding: 8px 10px;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      text-align: center;
      border-bottom: 2px solid var(--cyan);
    }
    .pricing-table thead th:first-child {
      text-align: left;
      color: var(--navy-dark);
    }
    .pricing-table thead .col-grid {
      color: var(--gray-text);
    }
    .pricing-table thead .col-smu {
      color: var(--cyan);
    }
    .pricing-table tbody td {
      padding: 8px 10px;
      border-bottom: 1px solid #EEF2F6;
      text-align: center;
    }
    .pricing-table tbody td:first-child {
      text-align: left;
      font-weight: 600;
      color: var(--navy-dark);
    }
    .pricing-table .grid-cell {
      color: var(--gray-text);
      text-decoration: line-through;
      opacity: 0.7;
    }
    .pricing-table .smu-cell {
      color: var(--cyan);
      font-weight: 800;
      font-size: 0.9rem;
    }
    .pricing-table .term-note {
      font-size: 0.68rem;
      color: var(--gray-text);
      font-weight: 400;
      display: block;
    }
    .card-term-slider {
      margin-bottom: 8px;
    }
    .card-term-slider label {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--navy);
      display: block;
      margin-bottom: 4px;
    }
    .card-term-slider input[type="range"] {
      -webkit-appearance: none;
      appearance: none;
      width: 100%;
      height: 6px;
      border-radius: 3px;
      background: linear-gradient(90deg, var(--cyan), rgba(0, 184, 212, 0.2));
      outline: none;
      cursor: pointer;
    }
    .card-term-slider input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--white);
      border: 2.5px solid var(--cyan);
      cursor: pointer;
      box-shadow: 0 2px 6px rgba(0, 184, 212, 0.4);
    }
    .card-term-slider input[type="range"]::-moz-range-thumb {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: var(--white);
      border: 2.5px solid var(--cyan);
      cursor: pointer;
      box-shadow: 0 2px 6px rgba(0, 184, 212, 0.4);
    }
    .card-term-labels {
      display: flex;
      justify-content: space-between;
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--navy);
      margin-top: 4px;
    }

    /* View Specs Button */
    .view-specs-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: none;
      border: 1.5px solid #D8E2EA;
      border-radius: 8px;
      padding: 8px 16px;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--gray-text);
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
      margin-top: 12px;
    }
    .view-specs-btn:hover {
      border-color: var(--cyan);
      color: var(--cyan);
    }

    /* Specs Modal */
    .specs-modal-overlay {
      position: fixed;
      inset: 0;
      z-index: 200;
      display: none;
    }
    .specs-modal-overlay.open { display: block; }
    .specs-modal-overlay .specs-backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.5);
      backdrop-filter: blur(4px);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .specs-modal-overlay.open .specs-backdrop { opacity: 1; }
    .specs-modal-container {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }
    .specs-modal-card {
      position: relative;
      background: var(--white);
      border-radius: 16px;
      width: 100%;
      max-width: 400px;
      padding: 28px;
      transform: translateY(20px);
      opacity: 0;
      transition: all 0.3s ease-out;
    }
    .specs-modal-overlay.open .specs-modal-card {
      transform: translateY(0);
      opacity: 1;
    }
    .specs-modal-close {
      position: absolute;
      top: 14px;
      right: 14px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--gray-text);
      padding: 4px;
    }
    .specs-modal-close:hover { color: var(--navy); }
    .specs-modal-title {
      font-size: 1.2rem;
      font-weight: 800;

<!-- Tab switching for Recommended Systems -->
<script is:inline>
  function switchTab(tab) {
    const container = document.getElementById('systems');
    container.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    container.querySelectorAll('.tab-panel').forEach(panel => panel.classList.remove('active'));

    if (tab === 'water') {
      document.getElementById('tab-water').classList.add('active');
      container.querySelectorAll('.tab-btn')[0].classList.add('active');
    } else {
      document.getElementById('tab-ice').classList.add('active');
      container.querySelectorAll('.tab-btn')[1].classList.add('active');
    }
  }
</script>

<!-- Specs Modal JavaScript -->
<script is:inline>
  const specsModal = document.getElementById('specs-modal');
  const specsTitle = document.getElementById('specs-modal-title');
  const specsList = document.getElementById('specs-modal-list');
  const specsClose = document.getElementById('specs-modal-close');
  const specsBackdrop = document.getElementById('specs-backdrop');

  document.querySelectorAll('.view-specs-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const specs = JSON.parse(btn.dataset.specs);
      const name = btn.dataset.name;
      specsTitle.textContent = `${name} Specifications`;
      specsList.innerHTML = specs.map(s => `<li><strong>${s.label}:</strong> ${s.value}</li>`).join('');
      specsModal.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeSpecsModal() {
    specsModal.classList.remove('open');
    document.body.style.overflow = '';
  }
  specsClose?.addEventListener('click', closeSpecsModal);
  specsBackdrop?.addEventListener('click', closeSpecsModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && specsModal.classList.contains('open')) closeSpecsModal();
  });
</script>

<!-- Card Pricing Slider JS -->
<script is:inline>
  function fmt(n) {
    return '$' + n.toLocaleString();
  }
  function updateCardPricing(card, idx) {
    const prices = JSON.parse(card.dataset.prices);
    const tpRow = card.querySelector('.row-tp');
    const rentalRow = card.querySelector('.row-rental');
    const purchaseRow = card.querySelector('.row-purchase');

    tpRow.querySelectorAll('.grid-cell')[0].textContent = fmt(prices.tp.grid[idx]);
    tpRow.querySelectorAll('.smu-cell')[0].textContent = fmt(prices.tp.smu[idx]);
    rentalRow.querySelectorAll('.grid-cell')[0].textContent = fmt(prices.rental.grid[idx]);
    rentalRow.querySelectorAll('.smu-cell')[0].textContent = fmt(prices.rental.smu[idx]);
    purchaseRow.querySelectorAll('.grid-cell')[0].textContent = '—';
    purchaseRow.querySelectorAll('.smu-cell')[0].textContent = fmt(prices.purchase);
  }

  document.querySelectorAll('.card-pricing[data-prices]').forEach(card => {
    // Set initial values (60mo = index 0)
    updateCardPricing(card, 0);

    // Listen for slider changes
    const slider = card.querySelector('.card-term-range');
    slider?.addEventListener('input', () => {
      updateCardPricing(card, parseInt(slider.value));
    });
  });
</script>


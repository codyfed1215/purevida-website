---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: "How much does it cost?",
    answer: "There is a one-time $99 installation fee. Beyond that, PureVida's full-service rental runs between $54 and $309 per month depending on what you need. PureVida typically bills quarterly."
  },
  {
    question: "What is included?",
    answer: "Everything. PureVida's full-service rental covers all parts, service, filters, and filter changes. If your system breaks, PureVida fixes it. If PureVida can't fix it, PureVida replaces it. PureVida also includes free relocations. PureVida's industrial-grade filters are built to last, though PureVida changes them at least once a year to ensure peak performance. If you ever need anything, just reach out and PureVida will take care of it."
  },
  {
    question: "How does installation work?",
    answer: "PureVida's Field Technicians handle everything and installation can take as little as 45 minutes. You tell PureVida where you want the system, and PureVida runs flexible, durable, quarter-inch polyethylene lines from the back of the unit to an existing water source and drain in your building, similar to how data cabling runs through your facility. The water source and drain do not need to be near the system—only a power source does. PureVida uses push-to-connect fittings that piggyback off your existing plumbing. PureVida has thousands of systems installed across all types of buildings and environments."
  },
  {
    question: "Is the water really high quality?",
    answer: "Absolutely. PureVida transforms any potable water source into exceptional drinking water through PureVida's 6-Stage Filtration: (1) Sediment Filter — removes dirt, rust, silt, and sand; (2) Carbon Block Filter — removes chlorine, chemicals, herbicides, pesticides, and VOCs; (3) Reverse Osmosis Membrane — filters down to 0.0001 micron, removing heavy metals, PFAs, microplastics, pharmaceuticals, and dissolved solids; (4) Granular Activated Carbon Filter — polishes the water for taste and removes residual organics; (5) Boost Filter (Remineralization) — adds back essential minerals and electrolytes (Potassium, Sodium, Calcium, Magnesium) while increasing the pH (standard on select systems, optional upgrade on others); and (6) Auto Active Purification — UV Light or Ozonation with Activated Oxygen runs continuously to keep the water and the system tank pristine. You'll taste the difference in your Free, No-Obligation Trial."
  },
  {
    question: "What is my responsibility with the Coffee System?",
    answer: "PureVida handles installation and all service on your coffee system. Your company is responsible for sourcing and purchasing coffee beans and powders—there are hundreds of online and drop-ship options to fit any budget and preference, and PureVida will point you in the right direction for compatible powders. There is also a quick daily and weekly cleaning routine that takes just a few minutes. PureVida recommends designating a Coffee Liaison in your office, and the PureVida team will fully train and support them."
  },
  {
    question: "Is it a commitment?",
    answer: "Yes. PureVida is installing a valuable piece of equipment for really no major up front purchase required, just an ongoing payment that covers everything. In return for this, PureVida asks for Price Protection Terms. After your Free, No-Obligation Trial, you choose a Price Protection term — 12, 36, or 60 months — and your monthly rate is locked in for the entire term. The majority of PureVida's customers choose the 60-month option because it gives them the lowest possible monthly payment with Price Protection for 5 full years. In a world where most operating costs only go up — rent, payroll, supplies, utilities — locking in a flat monthly rate for half a decade is a benefit that's easy to overlook, but a real one. Plus, for the entire Price Protection term, everything is included: parts, service, filters, filter changes, free relocations, and PureVida's Replacement Guarantee — if it breaks, PureVida fixes it. If PureVida cannot fix it, PureVida replaces it. You also experience the system through your Free, No-Obligation Trial before you ever commit to or pay for anything. If you need to cancel early, you can pay off the remainder of your Price Protection term and PureVida will pick up the equipment at no additional charge."
  }
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
});
---

<Layout
  title="Bottle-less Water Cooler FAQs"
  description="Frequently asked questions about PureVida Water Technologies bottle-less water coolers, ice machines, and coffee systems. Learn about pricing, installation, and service."
>
  <script type="application/ld+json" set:html={faqSchema} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-sky-50 to-white py-8 lg:py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl lg:text-5xl font-bold text-gray-900">
        Bottle-less Water Cooler FAQs
      </h1>
      <p class="mt-4 text-xl text-gray-600">
        Everything you need to know about PureVida's systems and service.
      </p>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-6">
        {faqs.map((faq, index) => (
          <div class="border border-gray-200 rounded-2xl overflow-hidden">
            <button
              class="faq-toggle w-full px-6 py-5 text-left flex items-center justify-between bg-white hover:bg-gray-50 transition"
              data-faq={index}
            >
              <span class="text-lg font-semibold text-gray-900">{faq.question}</span>
              <svg class="faq-icon w-5 h-5 text-sky-500 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="faq-content hidden px-6 pb-5">
              <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Still Have Questions -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Still Have Questions?</h2>
      <p class="text-gray-600 mb-8">
        PureVida is here to help. Reach out and PureVida will get back to you immediately.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center bg-sky-500 hover:bg-sky-600 text-white px-8 py-4 rounded-xl font-semibold text-lg transition shadow-lg shadow-sky-500/30">
          Contact Us
        </a>
        <a href="tel:+18885340117" class="inline-flex items-center justify-center border-2 border-gray-300 hover:border-sky-500 text-gray-700 hover:text-sky-500 px-8 py-4 rounded-xl font-semibold text-lg transition">
          (888) 534-0117
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-sky-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to Try It?</h2>
      <p class="mt-4 text-xl text-sky-100">
        Free, no-obligation trial with full-service support.
      </p>
      <div class="mt-8">
        <button data-trial-modal class="inline-flex items-center justify-center bg-white text-sky-600 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-sky-50 transition cursor-pointer">
          Request Free Trial
        </button>
      </div>
    </div>
  </section>

  <script>
    const toggles = document.querySelectorAll('.faq-toggle');

    toggles.forEach(toggle => {
      toggle.addEventListener('click', () => {
        const content = toggle.nextElementSibling;
        const icon = toggle.querySelector('.faq-icon');

        // Close all other FAQs
        toggles.forEach(otherToggle => {
          if (otherToggle !== toggle) {
            const otherContent = otherToggle.nextElementSibling;
            const otherIcon = otherToggle.querySelector('.faq-icon');
            otherContent?.classList.add('hidden');
            otherIcon?.classList.remove('rotate-180');
          }
        });

        // Toggle current FAQ
        content?.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      });
    });
  </script>
</Layout>

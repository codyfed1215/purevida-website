---
import Layout from '../../layouts/Layout.astro';
import BlogHeroImage from '../../components/BlogHeroImage.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const categoryLabels: Record<string, string> = {
  'water-quality': 'Water Quality',
  'cost-comparison': 'Cost Comparison',
  'buyer-guide': 'Buyer Guide',
  products: 'Products',
};
---

<Layout
  title="Blog"
  description="Expert insights on bottleless water coolers, ice machines, water quality, and cost savings for Texas businesses. Tips from PureVida Water Technologies."
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-sky-50 to-white py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl lg:text-5xl font-bold text-gray-900">The PureVida Blog</h1>
      <p class="mt-4 text-xl text-gray-600 max-w-2xl mx-auto">
        Expert insights on water quality, cost savings, and smarter hydration for Texas businesses.
      </p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:border-sky-300 hover:shadow-lg transition"
          >
            <BlogHeroImage category={post.data.category} size="card" />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="bg-sky-100 text-sky-700 text-xs font-medium px-2.5 py-0.5 rounded-full">
                  {categoryLabels[post.data.category]}
                </span>
                <time class="text-xs text-gray-400" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h2 class="text-xl font-semibold text-gray-900 group-hover:text-sky-600 transition line-clamp-2">
                {post.data.title}
              </h2>
              <p class="mt-2 text-gray-500 line-clamp-3">{post.data.description}</p>
              <span class="inline-flex items-center mt-4 text-sky-500 font-medium">
                Read More
                <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-sky-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white">Ready to Make the Switch?</h2>
      <p class="mt-4 text-xl text-sky-100">
        Free, no-obligation trial with full-service support for Texas businesses.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <button data-trial-modal class="inline-flex items-center justify-center bg-white text-sky-600 px-8 py-4 rounded-xl font-semibold text-lg hover:bg-sky-50 transition cursor-pointer">
          Request Free Trial
        </button>
        <a href="tel:+18885340117" class="inline-flex items-center justify-center border-2 border-white text-white px-8 py-4 rounded-xl font-semibold text-lg hover:bg-white/10 transition">
          Call (888) 534-0117
        </a>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from './Layout.astro';
import BlogHeroImage from '../components/BlogHeroImage.astro';
import BlogCTA from '../components/BlogCTA.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  category: 'water-quality' | 'cost-comparison' | 'buyer-guide' | 'products';
  tags: string[];
  currentSlug: string;
}

const { title, description, date, author, category, tags, currentSlug } = Astro.props;

const categoryLabels: Record<string, string> = {
  'water-quality': 'Water Quality',
  'cost-comparison': 'Cost Comparison',
  'buyer-guide': 'Buyer Guide',
  products: 'Products',
};

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Reading time estimate
const slotContent = await Astro.slots.render('default');
const wordCount = slotContent.replace(/<[^>]*>/g, '').split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 225));

// Related posts
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== currentSlug)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const siteUrl = 'https://purevidawater.com';
const canonical = `${siteUrl}/blog/${currentSlug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  author: { '@type': 'Organization', name: 'PureVida Water Technologies' },
  publisher: {
    '@type': 'Organization',
    name: 'PureVida Water Technologies',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/images/water-drop-logo.png` },
  },
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---

<Layout title={title} description={description} canonicalUrl={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} slot="head" />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} slot="head" />

  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Breadcrumbs -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-sky-500 transition">Home</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <a href="/blog" class="hover:text-sky-500 transition">Blog</a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <span class="text-gray-400 truncate max-w-[200px]">{title}</span>
    </nav>

    <!-- Hero Image -->
    <BlogHeroImage category={category} size="hero" />

    <!-- Header -->
    <header class="mt-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="bg-sky-100 text-sky-700 text-sm font-medium px-3 py-1 rounded-full">{categoryLabels[category]}</span>
      </div>
      <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 leading-tight">{title}</h1>
      <div class="flex flex-wrap items-center gap-4 mt-4 text-sm text-gray-500">
        <span>{author}</span>
        <span class="text-gray-300">|</span>
        <time datetime={date.toISOString()}>{formattedDate}</time>
        <span class="text-gray-300">|</span>
        <span>{readingTime} min read</span>
      </div>
    </header>

    <!-- Content -->
    <div class="blog-prose mt-10">
      <slot />
    </div>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-10 pt-6 border-t border-gray-200">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="bg-gray-100 text-gray-600 text-sm px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      </div>
    )}

    <!-- CTA -->
    <BlogCTA />
  </article>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="bg-gray-50 py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8">More from the Blog</h2>
        <div class="grid md:grid-cols-3 gap-8">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="group bg-white rounded-2xl overflow-hidden border border-gray-200 hover:border-sky-300 hover:shadow-lg transition">
              <BlogHeroImage category={post.data.category} size="card" />
              <div class="p-6">
                <span class="bg-sky-100 text-sky-700 text-xs font-medium px-2 py-0.5 rounded-full">
                  {categoryLabels[post.data.category]}
                </span>
                <h3 class="mt-3 text-lg font-semibold text-gray-900 group-hover:text-sky-600 transition line-clamp-2">{post.data.title}</h3>
                <p class="mt-2 text-sm text-gray-500 line-clamp-2">{post.data.description}</p>
                <span class="inline-flex items-center mt-4 text-sm text-sky-500 font-medium">
                  Read More
                  <svg class="ml-1 w-4 h-4 group-hover:translate-x-1 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>
